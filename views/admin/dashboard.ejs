<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>ORA Admin Dashboard - Tailwind</title>

  <!-- Tailwind Play CDN (no build step) -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Chart.js CDN -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

  <style>
    /* small custom scrollbar for sidebar */
    .sidebar-scroll::-webkit-scrollbar { width: 8px; }
    .sidebar-scroll::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.12); border-radius: 999px; }
  </style>
</head>
<body class="bg-gray-100 text-slate-800 antialiased">

  <!-- Container -->
  <div class="min-h-screen flex">

    <!-- Sidebar -->
    <aside id="sidebar" class="hidden md:flex md:w-72 lg:w-80 bg-white/90 border-r border-gray-200 sidebar-scroll flex-col p-6">
      <div class="flex items-center gap-3 mb-8">
        <div class="text-3xl font-handwritten text-2xl text-yellow-400">ORA</div>
        <div class="ml-auto">
          <button class="text-sm text-gray-500">Admin</button>
        </div>
      </div>

      <nav class="flex-1">
        <ul class="space-y-1">
          <!-- active -->
          <li>
            <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-black text-white shadow">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10zM3 21h8v-6H3v6zM13 21h8V11h-8v10zM13 3v6h8V3h-8z" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span class="font-medium">Dashboard</span>
            </a>
          </li>

          <!-- items -->
          <li>
            <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50">
              <svg class="w-5 h-5 text-gray-500" viewBox="0 0 24 24" fill="none"><path d="M3 7h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M6 11h12M9 15h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span class="text-sm text-gray-700">Order</span>
            </a>
          </li>

          <li>
            <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><rect x="3" y="7" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/></svg>
              <span class="text-sm text-gray-700">Products</span>
            </a>
          </li>

          <li><a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M3 7h18" stroke="currentColor" stroke-width="1.5"/></svg><span class="text-sm text-gray-700">Sales report</span></a></li>

          <li class="mt-4"><hr class="border-gray-100"></li>

          <li class="mt-3"><a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M12 12a5 5 0 100-10 5 5 0 000 10zM4 21a8 8 0 0116 0" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg><span class="text-sm text-gray-700">Customer</span></a></li>

          <li><a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M12 2l2 4 4 .6-3 3 1 4-4-2-4 2 1-4-3-3 4-.6L12 2z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg><span class="text-sm text-gray-700">Coupon</span></a></li>

          <li><a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.2"/></svg><span class="text-sm text-gray-700">Banners</span></a></li>

          <li class="mt-6">
            <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50 text-sm text-red-600">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M6 9v10a2 2 0 002 2h8a2 2 0 002-2V9" stroke="currentColor" stroke-width="1.2"/><path d="M10 4h4v4h-4z" stroke="currentColor" stroke-width="1.2"/></svg>
              <span>Sign Out</span>
            </a>
          </li>
        </ul>
      </nav>

      <div class="mt-6 text-xs text-gray-400">
        © 2025 | ORA
      </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 min-h-screen">

      <!-- Topbar for small screens -->
      <header class="md:hidden bg-white border-b border-gray-200 px-4 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <button id="mobileMenuBtn" class="p-2 rounded-md bg-gray-100">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M3 12h18M3 6h18M3 18h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="text-2xl font-handwritten text-yellow-400">ORA</div>
        </div>

        <div class="flex items-center gap-3">
          <button class="p-2 rounded-md bg-gray-100">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="w-8 h-8 rounded-full bg-gray-200"></div>
        </div>
      </header>

      <!-- Mobile sliding menu -->
      <div id="mobileMenu" class="md:hidden fixed inset-0 bg-black/40 z-40 hidden">
        <div class="absolute left-0 top-0 bottom-0 w-64 bg-white p-5">
          <div class="flex items-center justify-between mb-6">
            <div class="text-lg font-handwritten text-yellow-400">ORA</div>
            <button id="mobileClose" class="text-gray-500">&times;</button>
          </div>

          <nav>
            <ul class="space-y-2">
              <li><a href="#" class="block px-3 py-2 rounded-lg bg-black text-white">Dashboard</a></li>
              <li><a href="#" class="block px-3 py-2 rounded-lg hover:bg-gray-100">Order</a></li>
              <li><a href="#" class="block px-3 py-2 rounded-lg hover:bg-gray-100">Products</a></li>
              <li><a href="#" class="block px-3 py-2 rounded-lg hover:bg-gray-100">Customer</a></li>
              <li><a href="#" class="block px-3 py-2 rounded-lg hover:bg-gray-100 text-red-600">Sign Out</a></li>
            </ul>
          </nav>
        </div>
      </div>

      <!-- Page content -->
      <main class="p-6 lg:p-10">
        <!-- Top summary cards -->
        <div class="flex flex-col md:flex-row gap-4 items-stretch">
          <div class="flex-1 rounded-lg bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between">
              <div>
                <div class="text-xs text-gray-400">Total Customers</div>
                <div class="text-2xl font-semibold">5,423</div>
                <div class="text-xs text-green-500 mt-1">+10% this month</div>
              </div>
              <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center">
                <!-- icon -->
                <svg class="w-6 h-6 text-emerald-500" viewBox="0 0 24 24" fill="none"><path d="M12 12a5 5 0 100-10 5 5 0 000 10zM3 21a8 8 0 0116 0" stroke="currentColor" stroke-width="1.2"/></svg>
              </div>
            </div>
          </div>

          <div class="flex-1 rounded-lg bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between">
              <div>
                <div class="text-xs text-gray-400">Total Orders</div>
                <div class="text-2xl font-semibold">1,893</div>
                <div class="text-xs text-green-500 mt-1">5% this month</div>
              </div>
              <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-500" viewBox="0 0 24 24" fill="none"><path d="M3 3h18v18H3z" stroke="currentColor" stroke-width="1.2"/></svg>
              </div>
            </div>
          </div>

          <div class="flex-1 rounded-lg bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between">
              <div>
                <div class="text-xs text-gray-400">Total Sales</div>
                <div class="text-2xl font-semibold">₹65,805</div>
                <div class="text-xs text-green-500 mt-1">+8% this month</div>
              </div>
              <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-500" viewBox="0 0 24 24" fill="none"><path d="M12 1v22" stroke="currentColor" stroke-width="1.2"/></svg>
              </div>
            </div>
          </div>

          <div class="flex-1 rounded-lg bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between">
              <div>
                <div class="text-xs text-gray-400">Total Pending</div>
                <div class="text-2xl font-semibold">189</div>
                <div class="text-xs text-red-500 mt-1">-2% this month</div>
              </div>
              <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-500" viewBox="0 0 24 24" fill="none"><path d="M12 2a10 10 0 100 20 10 10 0 000-20z" stroke="currentColor" stroke-width="1.2"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Sales details section -->
        <section class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Left: Sales progress card -->
          <div class="lg:col-span-1 bg-white rounded-lg p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-md font-semibold">Sales Progress</h3>
              <div class="text-xs text-gray-400">This Quarter</div>
            </div>

            <!-- faux circular progress -->
            <div class="flex items-center gap-4">
              <div class="w-32 h-32 relative">
                <svg viewBox="0 0 36 36" class="w-full h-full">
                  <path class="text-gray-200" stroke="#eef2f7" stroke-width="4" fill="none" d="M18 2a16 16 0 1 1 0 32 16 16 0 0 1 0-32"></path>
                  <path class="text-blue-500" stroke="#4f46e5" stroke-width="4" stroke-linecap="round" fill="none" stroke-dasharray="75 100" d="M18 2a16 16 0 1 1 0 32 16 16 0 0 1 0-32"></path>
                </svg>
                <div class="absolute inset-0 grid place-items-center">
                  <div class="text-center">
                    <div class="text-xl font-semibold">75.55%</div>
                    <div class="text-xs text-green-500">+10%</div>
                  </div>
                </div>
              </div>

              <div class="flex-1">
                <p class="text-sm text-gray-500 mb-3">
                  You succeed earn ₹28963 today, it's higher than yesterday.
                </p>

                <div class="flex gap-3 text-xs text-gray-500">
                  <div class="flex-1">
                    <div class="text-xs text-gray-400">Target</div>
                    <div class="text-sm font-semibold">₹30k</div>
                  </div>
                  <div class="flex-1">
                    <div class="text-xs text-gray-400">Revenue</div>
                    <div class="text-sm font-semibold">₹16k</div>
                  </div>
                  <div class="flex-1">
                    <div class="text-xs text-gray-400">Today</div>
                    <div class="text-sm font-semibold">₹28k</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right: Activity Chart -->
          <div class="lg:col-span-2 bg-white rounded-lg p-5 shadow-sm">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-md font-semibold">Activity</h3>
              <select class="border px-3 py-1 rounded text-sm text-gray-600">
                <option>Month</option>
                <option>Week</option>
                <option>Year</option>
              </select>
            </div>

            <div class="h-64">
              <canvas id="activityChart" class="w-full h-full"></canvas>
            </div>
          </div>
        </section>

        <!-- Footer small -->
        <div class="mt-8 text-center text-xs text-gray-400">
          © 2025 | ORA | All Rights Reserved.
        </div>
      </main>
    </div>
  </div>

  <!-- Scripts -->
  <script>
    // Mobile menu toggles
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileClose = document.getElementById('mobileClose');

    mobileMenuBtn?.addEventListener('click', () => {
      mobileMenu.classList.remove('hidden');
    });
    mobileClose?.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
    });
    mobileMenu?.addEventListener('click', (e) => {
      if (e.target === mobileMenu) mobileMenu.classList.add('hidden');
    });

    // Chart.js activity chart
    const ctx = document.getElementById('activityChart').getContext('2d');

    const gradient = ctx.createLinearGradient(0,0,0,300);
    gradient.addColorStop(0, 'rgba(79,70,229,0.12)');
    gradient.addColorStop(1, 'rgba(79,70,229,0)');

    const activityChart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
        datasets: [{
          label: 'Activity',
          data: [60,80,120,140,160,180,200,260,280,320,350,380],
          backgroundColor: gradient,
          borderColor: '#4f46e5',
          borderWidth: 1,
          hoverBackgroundColor: 'rgba(79,70,229,0.18)',
          borderRadius: 6,
        }]
      },
      options: {
        maintainAspectRatio: false,
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: '#6b7280' }
          },
          y: {
            grid: {
              drawBorder: false,
              color: 'rgba(15,23,42,0.06)',
            },
            ticks: {
              color: '#6b7280',
              beginAtZero: true
            }
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#111827',
            titleColor: '#fff',
            bodyColor: '#fff'
          }
        }
      }
    });
  </script>

</body>
</html>
