<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Edit Product</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link rel="stylesheet" href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.css" />
  <script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.js"></script>
</head>

<body class="bg-gray-100">
  <div class="flex min-h-screen">
    <%- include("../partials/admin/sidebar") %>

      <div class="flex flex-col flex-1 ml-64">
        <main class="p-6 flex-1">
          <h2 class="text-2xl font-semibold mb-6">Edit Product</h2>

          <!-- FORM -->
          <form id="editProductForm" data-id="<%= product._id %>" class="bg-white shadow rounded-lg p-6 space-y-6"
            enctype="multipart/form-data">

            <div>
              <label class="block text-gray-700 font-medium mb-2">Product Name</label>
              <input id="productname" name="productname" type="text" value="<%= product.productname %>"
                class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400" />
            </div>

            <div>
              <label class="block text-gray-700 font-medium mb-2">Product Description</label>
              <textarea id="description" name="description" rows="4"
                class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400"><%= product.description %></textarea>
            </div>

            <!-- Category / SubCategory / Brand -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-gray-700 font-medium mb-2">Category</label>
                <select id="category" name="category_Id"
                  class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">
                  <option value="">-- Select category --</option>
                  <% categories.forEach(cat=> { %>
                    <option value="<%= cat._id %>" <%=product.category_Id && String(product.category_Id._id ||
                      product.category_Id)===String(cat._id) ? "selected" : "" %>><%= cat.name %>
                    </option>
                    <% }) %>
                </select>
              </div>

              <div>
                <label class="block text-gray-700 font-medium mb-2">SubCategory</label>
                <select id="subcategory" name="subcategory_Id"
                  class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">
                  <option value="">-- Select subcategory --</option>
                  <% subcategories.forEach(sub=> { %>
                    <option value="<%= sub._id %>" <%=product.subcategory_Id && String(product.subcategory_Id._id ||
                      product.subcategory_Id)===String(sub._id) ? "selected" : "" %>><%= sub.name %>
                    </option>
                    <% }) %>
                </select>
              </div>

              <div>
                <label class="block text-gray-700 font-medium mb-2">Brand</label>
                <select id="brand" name="brand"
                  class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">
                  <option value="">-- Select brand --</option>
                  <% brands.forEach(b=> { %>
                    <option value="<%= b %>" <%=product.brand===b ? "selected" : "" %>><%= b %>
                    </option>
                    <% }) %>
                </select>
              </div>
            </div>

            <!-- Material / Dial Type -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-gray-700 font-medium mb-2">Material</label>
                <select id="material" name="material"
                  class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">
                  <option value="">-- Select material --</option>
                  <% materials.forEach(m=> { %>
                    <option value="<%= m %>" <%=product.material===m ? "selected" : "" %>><%= m %>
                    </option>
                    <% }) %>
                </select>
              </div>

              <div>
                <label class="block text-gray-700 font-medium mb-2">Dial Type</label>
                <select id="dialType" name="dialType"
                  class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">
                  <option value="">-- Select dial type --</option>
                  <% dials.forEach(d=> { %>
                    <option value="<%= d %>" <%=product.dialType===d ? "selected" : "" %>><%= d %>
                    </option>
                    <% }) %>
                </select>
              </div>
            </div>

            <div id="variantsContainer">
              <% variants.forEach(v=> { %>

                <div class="variant-box border rounded-xl p-4 mb-6 bg-white shadow-sm" data-variant-id="<%= v._id %>">

                  <!-- Variant Header -->
                  <div class="flex justify-between items-center mb-3">
                    <h3 class="font-bold text-lg">Variant (<%= v.color %>)</h3>
                  </div>

                  <input type="hidden" name="variantIds[]" value="<%= v._id %>">

                  <!-- Row: Color, Price, Stock -->
                  <div class="grid grid-cols-3 gap-4 mb-4">

                    <div>
                      <label class="font-semibold">Color</label>
                      <input type="text" name="color_<%= v._id %>" value="<%= v.color %>"
                        class="w-full border rounded p-2">
                    </div>

                    <div>
                      <label class="font-semibold">Price</label>
                      <input type="number" name="price_<%= v._id %>" value="<%= v.price %>"
                        class="w-full border rounded p-2">
                    </div>

                    <div>
                      <label class="font-semibold">Stock</label>
                      <input type="number" name="stock_<%= v._id %>" value="<%= v.stock %>"
                        class="w-full border rounded p-2">
                    </div>
                  </div>

                  <!-- Images -->
                  <label class="font-semibold block mb-1">Images</label>
                  <div class="grid grid-cols-6 gap-1">
                    <% v.images.forEach(img=> { %>
                      <div class="relative group p-0 m-0">
                        <input type="checkbox" name="removeImages_<%= v._id %>[]" value="<%= img %>"
                          class="absolute top-1 left-1 w-4 h-4 z-10 cursor-pointer">
                        <img src="<%= img %>" class="w-12 h-12 object-cover rounded border shadow-sm">
                      </div>
                      <% }) %>

                  </div>

                  <!-- Add New Images -->
                  <label class="font-semibold block mt-4">Add New Images</label>
                  <input type="file" class="variant-image-input" data-variant="<%= v._id %>"
                    name="variantImages_<%= v._id %>[]" multiple>
                  <div class="new-images-preview flex gap-2 mt-2" data-variant="<%= v._id %>">
                  </div>

                </div>

                <% }) %>
            </div>
            <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
              <button type="reset" class="px-4 py-2 border border-gray-300 rounded hover:bg-gray-100">Cancel</button>
              <button id="saveProductBtn" type="submit"
                class="px-4 py-2 bg-black text-white rounded hover:bg-gray-800">Edit</button>
            </div>
          </form>
        </main>
      </div>
  </div>
  <div id="cropModal" class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50">
    <div class="bg-white p-4 rounded-lg max-w-lg w-full">
      <img id="cropImage" class="max-w-full max-h-[70vh] mx-auto" />

      <div class="flex justify-end gap-2 mt-4">
        <button type="button" id="cropCancel" class="px-4 py-2 border">Cancel</button>






        <button type="button" id="cropConfirm" class="px-4 py-2 bg-black text-white">Crop & Use</button>
      </div>
    </div>
  </div>

  <%- include("../partials/admin/footer") %>


    <script>
      document.addEventListener("DOMContentLoaded", () => {

        let selectedFiles = [];
        let currentInput = null;
        let currentFileIndex = 0;
        let cropper = null;


        document.querySelectorAll(".variant-image-input").forEach(input => {
          input.addEventListener("change", e => {
            selectedFiles = Array.from(e.target.files);
            if (!selectedFiles.length) return;

            currentInput = input;
            currentFileIndex = 0;

            openCropper(selectedFiles[currentFileIndex]);
          });
        });

        //To open cropper
        function openCropper(file) {
          const reader = new FileReader();

          reader.onload = () => {
            const img = document.getElementById("cropImage");

            if (cropper) {
              cropper.destroy();
              cropper = null;
            }

            img.src = reader.result;

            const modal = document.getElementById("cropModal");
            modal.classList.remove("hidden");
            modal.classList.add("flex");

            cropper = new Cropper(img, {
              aspectRatio: 1,
              viewMode: 1,
              autoCropArea: 1,
              responsive: true,
            });
          };

          reader.readAsDataURL(file);
        }

        //confirm crop
        document.getElementById("cropConfirm").addEventListener("click", () => {
          if (!cropper) return;

          cropper.getCroppedCanvas({
            width: 800,
            height: 800,
            imageSmoothingQuality: "high"
          }).toBlob(blob => {

            const croppedFile = new File(
              [blob],
              `cropped_${Date.now()}.jpg`,
              { type: "image/jpeg" }
            );

            selectedFiles[currentFileIndex] = croppedFile;

            cropper.destroy();
            cropper = null;
            currentFileIndex++;

            if (currentFileIndex < selectedFiles.length) {
              openCropper(selectedFiles[currentFileIndex]);
            } else {
              finalizeFiles();
            }
          }, "image/jpeg", 0.9);
        });

        document.getElementById("cropCancel").addEventListener("click", () => {
          if (cropper) {
            cropper.destroy();
            cropper = null;
          }
          closeCropper();
        });

        function finalizeFiles() {
          const dt = new DataTransfer();
          selectedFiles.forEach(f => dt.items.add(f));
          currentInput.files = dt.files;

          const variantId = currentInput.dataset.variant;
          const previewBox = document.querySelector(
            `.new-images-preview[data-variant="${variantId}"]`
          );

          previewBox.innerHTML = "";

          selectedFiles.forEach(file => {
            const reader = new FileReader();
            reader.onload = e => {
              const img = document.createElement("img");
              img.src = e.target.result;
              img.className = "w-16 h-16 rounded border object-cover";
              previewBox.appendChild(img);
            };
            reader.readAsDataURL(file);
          });

          closeCropper();
        }

        function closeCropper() {
          const modal = document.getElementById("cropModal");
          modal.classList.add("hidden");
          modal.classList.remove("flex");
        }


        document.getElementById("editProductForm")
          .addEventListener("submit", async (e) => {
            e.preventDefault();

            const form = e.target;
            const productId = form.dataset.id;
            const fd = new FormData();

            fd.append("productname", form.productname.value);
            fd.append("description", form.description.value);
            fd.append("category_Id", form.category_Id.value);
            fd.append("subcategory_Id", form.subcategory_Id.value);
            fd.append("brand", form.brand.value);
            fd.append("material", form.material.value);
            fd.append("dialType", form.dialType.value);

            const variantBoxes = document.querySelectorAll(".variant-box");
            const variantsArr = [];

            variantBoxes.forEach(box => {
              const vid = box.dataset.variantId;

              variantsArr.push({
                _id: vid,
                color: box.querySelector(`[name="color_${vid}"]`).value,
                price: box.querySelector(`[name="price_${vid}"]`).value,
                stock: box.querySelector(`[name="stock_${vid}"]`).value,
                removeImages: Array.from(
                  box.querySelectorAll(`input[name="removeImages_${vid}[]"]:checked`)
                ).map(i => i.value)
              });

              const fileInput = box.querySelector(
                `[name="variantImages_${vid}[]"]`
              );

              if (fileInput?.files?.length) {
                Array.from(fileInput.files).forEach(f => {
                  fd.append(`variantImages_${vid}[]`, f);
                });
              }
            });

            fd.append("variants", JSON.stringify(variantsArr));

            try {
              const res = await fetch(
                `/admin/products/edit-product/${productId}`,
                { method: "PATCH", body: fd }
              );

              const data = await res.json();

              if (data.success) {
                await Swal.fire({
                  icon: "success",
                  title: "Updated",
                  text: data.message,
                  timer: 1400,
                  showConfirmButton: false
                });
                window.location.href = "/admin/products";
              } else {
                Swal.fire("Error", "Update failed", "error");
              }
            } catch (err) {
              console.error(err);
              Swal.fire("Error", "Server error", "error");
            }
          });

      });
    </script>

</body>

</html>