<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin-Customers</title>
    <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gray-100">
    <div class="flex min-h-screen">

        <%- include("../partials/admin/sidebar") %>
            <div class="flex flex-col flex-1 ml-64">
                <header
                    class="sticky top-0 z-20 p-6 bg-white shadow flex flex-wrap justify-between items-center border-b border-gray-200">
                    <h1 class="text-2xl font-bold text-gray-800">SubCategory</h1>
                    <form method="GET" action="/admin/customers" class="flex items-center gap-2 mt-4 md:mt-0">
                        <input type="text" name="search" value="" placeholder="Search here"
                            class="border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-yellow-400 focus:outline-none w-60">
                        <button type="submit"
                            class="px-4 py-2 bg-yellow-400 text-white rounded hover:bg-yellow-500 transition duration-200">
                            Search
                        </button>
                        <a href="/admin/customers"
                            class="px-4 py-2 bg-gray-300 text-gray-800 rounded hover:bg-gray-400 transition duration-200">Clear</a>

                    </form>
                </header>

                <main class="p-6 flex-1">
                    <div class="bg-white shadow rounded-lg p-4 overflow-x-auto">



                        <div class="flex gap-2 justify-end mb-3">
                            <button
                                class="bg-gray-900 text-white px-3 py-1.5 rounded hover:bg-blue-600 text-sm transition">
                                + Add New
                            </button>
                            <button
                                class="bg-gray-900 text-white px-3 py-1.5 rounded hover:bg-green-600 text-sm transition">
                                + Add Offer
                            </button>
                        </div>


                        <table class="w-full border-collapse">
                            <thead>
                                <tr class="border-b bg-gray-200">
                                    <th class="text-left px-4 py-2 font-semibold text-gray-700">SubCategory</th>
                                    <th class="text-center px-4 py-2 font-semibold text-gray-700">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="border-b hover:bg-gray-50 transition">
                                    <td class="px-4 py-2">Casual</td>
                                    <td class="px-4 py-2 text-center">
                                        <button class="text-blue-500 hover:text-blue-700 mx-1">🗑</button>

                                        <button class="text-red-500 hover:text-red-700 mx-1">✏️</button>

                                    </td>
                                </tr>
                                <tr class="border-b hover:bg-gray-50 transition">
                                    <td class="px-4 py-2">Formal</td>
                                    <td class="px-4 py-2 text-center">
                                        <button class="text-blue-500 hover:text-blue-700 mx-1">🗑</button>

                                        <button class="text-red-500 hover:text-red-700 mx-1">✏️</button>

                                    </td>
                                </tr>
                                <tr class="border-b hover:bg-gray-50 transition">
                                    <td class="px-4 py-2">Luxury</td>
                                    <td class="px-4 py-2 text-center">
                                        <button class="text-blue-500 hover:text-blue-700 mx-1">🗑</button>

                                        <button class="text-red-500 hover:text-red-700 mx-1">✏️</button>

                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- modal -->
                    <div id="confirmModal"
                        class="hidden fixed inset-0 bg-gray-800 bg-opacity-50 flex items-center justify-center z-50">
                        <div class="bg-white p-6 rounded-lg shadow-lg w-80 text-center">
                            <h2 id="modalTitle" class="text-lg font-semibold mb-4">Confirm Action</h2>
                            <p id="modalMessage" class="text-gray-600 mb-6"></p>
                            <div class="flex justify-center gap-4">
                                <button id="confirmBtn"
                                    class="bg-yellow-400 text-white px-4 py-2 rounded hover:bg-yellow-500">Yes</button>
                                <button id="cancelBtn"
                                    class="bg-gray-300 px-4 py-2 rounded hover:bg-gray-400">Cancel</button>
                            </div>
                        </div>
                        <div id="errMsg" class="text-red-500 text-sm"></div>
                        <div id="successMsg" class="text-green-500 text-sm"></div>
                    </div>




                </main>
                <%- include("../partials/admin/footer") %>
</body>

</html>