<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin-Customers</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body class="bg-gray-100">
 <div class="flex min-h-screen">

    <%- include("../partials/admin/sidebar") %>
      <div class="flex flex-col flex-1 ml-64">
        <header class="sticky top-0 z-20 p-6 bg-white shadow flex flex-wrap justify-between items-center border-b border-gray-200">
          <h1 class="text-2xl font-bold text-gray-800">Customers</h1>   
            <form method="GET" action="/admin/customers" class="flex items-center gap-2 mt-4 md:mt-0">
             <input type="text" name="search" value="<%= search %>" placeholder="Search here"
                    class="border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-yellow-400 focus:outline-none w-60">
             <button type="submit"
                    class="px-4 py-2 bg-yellow-400 text-white rounded hover:bg-yellow-500 transition duration-200">
                            Search
             </button>
             <a href="/admin/customers"class="px-4 py-2 bg-gray-300 text-gray-800 rounded hover:bg-gray-400 transition duration-200">Clear</a>
                            
            </form>
        </header>
<!-- Main Section -->
        <main class="p-6 flex-1">
            <div class="bg-white shadow rounded-lg overflow-hidden">
                <table class="min-w-full border-collapse">
                    <thead>
                        <tr class="bg-black text-white">
                          <th class="px-6 py-3 text-left text-sm font-medium">Email</th>
                          <th class="px-6 py-3 text-left text-sm font-medium">Customer</th>
                          <th class="px-6 py-3 text-left text-sm font-medium">Orders</th>
                          <th class="px-6 py-3 text-left text-sm font-medium">Balance</th>
                          <th class="px-6 py-3 text-left text-sm font-medium">Status</th>
                          <th class="px-6 py-3 text-left text-sm font-medium">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                    <% customers.forEach(customer => { %>
                     <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4"><%= customer.email %></td>
                        <td class="px-6 py-4"><%= customer.fullName %></td>
                        <td class="px-6 py-4"><%= customer.orders %></td>
                        <td class="px-6 py-4"><%= customer.walletBalance %></td>
                        <td class="px-6 py-4">
                           <span class="px-2 py-1 rounded-full text-xs font-semibold <%= customer.isBlocked ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700' %>">
                              <%= customer.isBlocked ? 'Blocked' : 'Active' %>
                            </span>
                        </td>
                        <td class="px-6 py-4 flex gap-2">
                        <% if (!customer.isBlocked) { %>
                          <button onclick="openModal('<%= customer._id %>', 'block')" class="text-red-500 hover:text-red-700" title="Block">🗑</button>
                        <% } else { %>
                           <button onclick="openModal('<%= customer._id %>', 'unblock')" class="text-green-500 hover:text-green-700" title="Unblock">✅</button>
                        <% } %>
                          <a href="/admin/customers/edit/<%= customer._id %>" class="text-blue-500 hover:text-blue-700" title="Edit">✏️</a>
                        </td>
                    </tr>
                    <% }) %>
                  </tbody>

            </table>
            </div>
            <!-- Modal -->
            <div id="confirmModal"class="hidden fixed inset-0 bg-gray-800 bg-opacity-50 flex items-center justify-center z-50">
                <div class="bg-white p-6 rounded-lg shadow-lg w-80 text-center">
                    <h2 id="modalTitle"class="text-lg font-semibold mb-4" >Confirm Action</h2>
                    <p id="modalMessage" class="text-gray-600 mb-6"></p>
                    <div class="flex justify-center gap-4">
                        <button id="confirmBtn"class="bg-yellow-400 text-white px-4 py-2 rounded hover:bg-yellow-500">Yes</button>
                        <button id="cancelBtn"class="bg-gray-300 px-4 py-2 rounded hover:bg-gray-400">Cancel</button>
                    </div>
                </div>
                
            </div>        
        <!-- pagination -->
                    <div class="mt-4 flex justify-center items-center space-x-2">
                        <a href="/admin/category?page=<%= page - 1 %>&search=<%= search %>"
                            class="px-3 py-1 border rounded hover:bg-gray-200 <%= page === 1 ? 'pointer-events-none opacity-50' : '' %>">
                            Prev
                        </a>
                        <% for (let i=1; i <=totalPages; i++) { %>
                        <a href="/admin/category?page=<%= i %>&search=<%= search %>"
                                class="px-3 py-1 border rounded <%= page === i ? 'bg-yellow-500 text-white' : 'hover:bg-gray-200' %>">
                                <%= i %>
                        </a>
                            <% } %>
                        <a href="/admin/category?page=<%= page + 1 %>&search=<%= search %>"
                                    class="px-3 py-1 border rounded hover:bg-gray-200 <%= page === totalPages ? 'pointer-events-none opacity-50' : '' %>">
                                    Next
                        </a>
                    </div>
                  
                            
        </main>                       
        <!-- Include Footer -->
                <%- include("../partials/admin/footer") %>            
    </div>
</div>

    <script>                   
       let selectedId = null;
       let actionType = null;

  const modal = document.getElementById('confirmModal');
  const modalTitle = document.getElementById('modalTitle');
  const modalMessage = document.getElementById('modalMessage');
  const confirmBtn = document.getElementById('confirmBtn');
  const cancelBtn = document.getElementById('cancelBtn');

  function openModal(id, type) {
    selectedId = id;
    actionType = type;

    modalTitle.textContent = type === 'block' ? 'Block Customer' : 'Unblock Customer';
    modalMessage.textContent =type === 'block'
        ? 'Are you sure you want to block this customer?'
        : 'Are you sure you want to unblock this customer?';
    modal.classList.remove('hidden');
  }

  cancelBtn.onclick = () => modal.classList.add('hidden');

  confirmBtn.onclick = async () => {
    try {
      const response = await fetch('/admin/customers/block', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: selectedId, action: actionType }),
      });

      const result = await response.json();
      if (result.success) {
        await Swal.fire({
        icon:'success',
        text:result.message,
        timer:2000,
        showConfirmationButton:false
      })
        location.reload();
      } else {
       Swal.fire({
        icon:'error',
        text:result.message,
        timer:2000,
        showConfirmationButton:false
      })
      }
    } catch (err) {
      console.error(err)
      Swal.fire({
        icon:'error',
        text:'Internal server error',
        timer:2000,
        showConfirmationButton:false
      })
    }
  };
</script>

</body>

</html>