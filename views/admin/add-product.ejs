<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Product</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link rel="stylesheet" href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.css" />
  <script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.js"></script>

</head>

<body class="bg-gray-100">
  <div class="flex min-h-screen">
    <%- include("../partials/admin/sidebar") %>
      <div class="flex flex-col flex-1 ml-64">
        <main class="p-6 flex-1">
          <h2 class="text-xl font-semibold mb-6">Add Product</h2>
          <form class="bg-white shadow rounded-lg p-6 space-y-6" id="add-form" enctype="multipart/form-data"
            onsubmit="return false;">
            <div>
              <label class="block text-gray-700 font-medium mb-2">Product Name</label>
              <input type="text" placeholder="Enter product name" id="productname" name="productname"
                class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">
            </div>
            <div>
              <label class="block text-gray-700 font-medium mb-2">Product Description</label>
              <textarea placeholder="Enter detailed product description..." id="description" name="description"
                class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400 h-24"></textarea>
            </div>

            <!-- Category / Sub Category / Brand -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-gray-700 font-medium mb-2">Category</label>
                <select id="category" name="category_Id"
                  class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">
                  <option value="">Select Category</option>
                  <% categories.forEach(category=> { %>
                    <option value="<%= category._id %>">
                      <%= category.name %>
                    </option>

                    <% }) %>
                </select>
              </div>
              <div>
                <label class="block text-gray-700 font-medium mb-2">SubCategory</label>
                <select id="subcategory" name="subcategory_Id"
                  class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">

                  <option value="">Select Subcategory</option>
                  <% subcategories.forEach(subcategory=> { %>
                    <option value="<%= subcategory._id %>">
                      <%= subcategory.name %>
                    </option>

                    <% }) %>
                </select>
              </div>
              <div>
                <label class="block text-gray-700 font-medium mb-2">Brand</label>
                <select name="brand" id="brand"
                  class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">
                  <option value="">Select brand</option>
                  <% brands.forEach(brand=> { %>
                    <option value="<%= brand %>">
                      <%= brand %>
                    </option>
                    <% }) %>
                </select>
              </div>
            </div>

            <!--Material / Dial Type -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-gray-700 font-medium mb-2">Material</label>
                <select name="material" id="material"
                  class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">
                  <option value="">Select Material</option>
                  <% materials.forEach(material=> { %>
                    <option value="<%= material %>">
                      <%= material%>
                    </option>
                    <% }) %>
                </select>
              </div>
              <div>
                <label class="block text-gray-700 font-medium mb-2">Dial Type</label>
                <select id="dialType" name="dialType"
                  class="w-full border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-yellow-400">
                  <option value="">Select DialType</option>
                  <% dials.forEach(dial=> { %>
                    <option value="<%= dial %>">
                      <%= dial %>
                    </option>
                    <% }) %>
                </select>
              </div>
            </div>

            <!-- Add Variant Button -->
            <button type="button" onclick="openModal()" id="openVariantModal"
              class="mt-4 bg-black text-white px-4 py-2 rounded-lg hover:bg-gray-800 ">
              + Add Variant
            </button>

            <!-- Variant Modal -->
            <div id="variantModal" class="fixed inset-0 bg-black/40 flex items-center justify-center hidden z-50">
              <div class="bg-white w-full max-w-lg rounded-2xl shadow-xl overflow-hidden">
                <div class="bg-black text-white text-center py-3 font-semibold text-lg">
                  Add Variant
                </div>

                <div class="p-6 space-y-4">
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-1">Price</label>
                      <input type="number" id="variantPrice" name="variantPrice"
                        class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring focus:ring-gray-400">
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-1">Stock</label>
                      <input type="number" id="variantStock" name="variantStock"
                        class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring focus:ring-gray-400">
                    </div>
                  </div>

                  <!-- Select Color -->
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Select Colour</label>
                    <input type="hidden" id="variantColor" name="variantColor">

                    <div class="flex gap-3">
                      <button type="button" data-color="RoseGold"
                        class="color-btn border-2 border-transparent rounded-lg px-4 py-2 bg-pink-200 hover:border-black">RoseGold</button>
                      <button type="button" data-color="Gold"
                        class="color-btn border-2 border-transparent rounded-lg px-4 py-2 bg-yellow-200 hover:border-black">Gold</button>
                      <button type="button" data-color="Silver"
                        class="color-btn border-2 border-transparent rounded-lg px-4 py-2 bg-gray-200 hover:border-black">Silver</button>
                      <button type="button" data-color="Black"
                        class="color-btn border-2 border-transparent rounded-lg px-4 py-2 bg-black text-white hover:border-black">Black</button>
                      <button type="button" data-color="Brown"
                        class="color-btn border-2 border-transparent rounded-lg px-4 py-2 bg-stone-600 hover:border-black">Brown</button>
                    </div>
                  </div>

                  <!-- variant Images Upload -->
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">variantImages</label>

                    <div id="dropZone"
                      class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:bg-gray-50 transition cursor-pointer">
                      <p class="text-sm text-gray-500">Drop images here, </p>
                      <p class="text-xs text-gray-400 mt-1">PNG, JPG </p>
                      <input type="file" id="variantImages" name="variantImages" class="hidden" multiple
                        accept="image/png, image/jpeg">
                      <button type="button"
                        class="mt-3 bg-black text-white text-sm px-4 py-2 rounded-lg hover:bg-gray-800">Choose
                        Files</button>
                    </div>

                    <!-- Image Preview -->
                    <div id="imagePreview" class="flex gap-3 mt-4 flex-wrap"></div>
                  </div>
                </div>

                <!-- Modal Footer -->
                <div class="flex justify-end gap-3 border-t border-gray-200 px-6 py-3">
                  <button type="button" onclick="closeModal()"
                    class="border border-gray-400 text-gray-700 px-5 py-2 rounded-lg hover:bg-gray-100">
                    Cancel
                  </button>
                  <button type="button" id="addVariantBtn"
                    class="bg-black text-white px-5 py-2 rounded-lg hover:bg-gray-800 transition">Add</button>
                </div>
              </div>
            </div>

            <input type="hidden" name="variants" id="variantData">
            <div id="variantList" class="mt-4 space-y-2"></div>


            <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
              <button type="reset" class="px-4 py-2 border border-gray-300 rounded hover:bg-gray-100">Cancel</button>
              <button type="submit" class="px-4 py-2 bg-black text-white rounded hover:bg-gray-800">Save</button>
            </div>
          </form>
        </main>
      </div>
  </div>
  <!-- Cropper Modal -->
  <div id="cropperModal" class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50">
    <div class="bg-white p-4 rounded-lg max-w-lg w-full">
      <div class="w-full max-h-[400px] overflow-hidden">
        <img id="cropperImage" class="max-w-full">
      </div>

      <div class="flex justify-end gap-3 mt-4">
        <button onclick="closeCropper()" class="px-4 py-2 border rounded">Cancel</button>
        <button onclick="confirmCrop()" class="px-4 py-2 bg-black text-white rounded">Crop & Use</button>
      </div>
    </div>
  </div>

  <%- include("../partials/admin/footer") %>
</body>

<script>
  function openModal() {
    document.getElementById('variantModal').classList.remove('hidden')
  }
  function closeModal() {
    document.getElementById('variantModal').classList.add('hidden')
  }

  /* ---------- Color buttons ---------- */
  document.querySelectorAll(".color-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".color-btn").forEach(b => b.classList.remove("ring-2", "ring-black"));
      btn.classList.add("ring-2", "ring-black");
      document.getElementById("variantColor").value = btn.dataset.color;
    });
  });

  /* ---------- Image selection & preview (modal-level) ---------- */
  const variantImagesInput = document.getElementById("variantImages");
  const dropZone = document.getElementById("dropZone");
  const imagePreview = document.getElementById("imagePreview");

  // files selected in the modal before adding the variant
  let variantSelectedFiles = [];

  dropZone.addEventListener("click", () => variantImagesInput.click());
  let cropper;
  let currentFile;
  let cropResolve;

  function openCropper(file) {
    return new Promise(resolve => {
      cropResolve = resolve;
      currentFile = file;

      const reader = new FileReader();
      reader.onload = e => {
        const img = document.getElementById("cropperImage");
        img.src = e.target.result;

        document.getElementById("cropperModal").classList.remove("hidden");

        cropper = new Cropper(img, {
          aspectRatio: 1,
          viewMode: 1,
          autoCropArea: 1
        });
      };
      reader.readAsDataURL(file);
    });
  }

  function closeCropper() {
    cropper?.destroy();
    cropper = null;
    document.getElementById("cropperModal").classList.add("hidden");
  }

  variantImagesInput.addEventListener("change", async () => {
    const files = Array.from(variantImagesInput.files || []);
    if (!files.length) return;

    for (const file of files) {
      // open cropper for EACH file
      const croppedFile = await openCropper(file);

      // store cropped file for this variant session
      variantSelectedFiles.push(croppedFile);

      // preview cropped image
      const reader = new FileReader();
      reader.onload = e => {
        const wrapper = document.createElement("div");
        wrapper.className =
          "relative w-24 h-24 rounded overflow-hidden border shadow-sm";

        wrapper.innerHTML = `
        <img src="${e.target.result}"
             class="w-full h-full object-cover">
      `;

        imagePreview.appendChild(wrapper);
      };
      reader.readAsDataURL(croppedFile);
    }

    // reset input so same file can be reselected
    variantImagesInput.value = "";
  });

  function confirmCrop() {
    cropper.getCroppedCanvas({
      width: 600,
      height: 600
    }).toBlob(blob => {
      const croppedFile = new File(
        [blob],
        currentFile.name,
        { type: blob.type }
      );

      closeCropper();
      cropResolve(croppedFile);
    }, "image/jpeg", 0.9);
  }
  let variants = [];
  let variantImagesMap = {};


  document.getElementById("addVariantBtn").addEventListener("click", () => {
    const price = document.getElementById("variantPrice").value.trim();
    const stock = document.getElementById("variantStock").value.trim();
    const color = document.getElementById("variantColor").value.trim();

    // use the files selected in the modal session
    const images = Array.from(variantSelectedFiles || []);

    // validations
    if (!price || isNaN(price) || Number(price) <= 0) {
      return Swal.fire({ icon: "error", text: "Enter a valid price" });
    }
    if (!stock || isNaN(stock) || Number(stock) < 0) {
      return Swal.fire({ icon: "error", text: "Enter a valid stock number" });
    }
    if (!color) {
      return Swal.fire({ icon: "error", text: "Select a color" });
    }
    if (images.length < 3) {
      return Swal.fire({ icon: "error", text: "Select at least 3 images for this variant" });
    }

    // push variant metadata and map its images to the variant index
    const variantIndex = variants.length; // next index
    variants.push({ price: Number(price), stock: Number(stock), color });
    variantImagesMap[variantIndex] = images.slice();


    document.getElementById("variantData").value = JSON.stringify(variants);

    document.getElementById("variantPrice").value = "";
    document.getElementById("variantStock").value = "";
    document.getElementById("variantColor").value = "";
    document.querySelectorAll(".color-btn").forEach(b => b.classList.remove("ring-2", "ring-black"));
    variantSelectedFiles = [];
    imagePreview.innerHTML = "";
    closeModal();

    // show list
    showVariants();
  });


  function showVariants() {
    const wrapper = document.getElementById("variantList");

    // create the table ONLY once
    wrapper.innerHTML = `
    <table class="w-full text-sm border rounded overflow-hidden mt-4">
      <thead class="bg-gray-100">
        <tr>
          <th class="px-3 py-2 text-left">Color</th>
          <th class="px-3 py-2 text-left">Price</th>
          <th class="px-3 py-2 text-left">Stock</th>
          <th class="px-3 py-2 text-left">Images</th>
        </tr>
      </thead>
      <tbody id="variantTableBody"></tbody>
    </table>
  `;

    const tableBody = document.getElementById("variantTableBody");
    tableBody.innerHTML = "";

    variants.forEach((v, i) => {
      const imagesCount = (variantImagesMap[i] || []).length;

      tableBody.insertAdjacentHTML(
        "beforeend",
        `
        <tr class="border-b">
          <td class="px-3 py-2">${v.color}</td>
          <td class="px-3 py-2">₹${v.price}</td>
          <td class="px-3 py-2">${v.stock}</td>
          <td class="px-3 py-2">${imagesCount} files</td>
        </tr>
      `
      );
    });
  }
  document.getElementById("add-form").addEventListener("submit", async (e) => {
    e.preventDefault();

    // basic product fields
    const productname = document.getElementById('productname').value.trim();
    const description = document.getElementById('description').value.trim();
    const category_Id = document.getElementById('category').value;
    const subcategory_Id = document.getElementById('subcategory').value;
    const brand = document.getElementById('brand').value;
    const material = document.getElementById('material').value;
    const dialType = document.getElementById('dialType').value;

    if (!productname || !description || !category_Id || !subcategory_Id || !brand || !material || !dialType) {
      return Swal.fire({ icon: 'error', text: 'Please fill all required fields' });
    }
    if (variants.length === 0) {
      return Swal.fire({ icon: 'error', text: 'Add at least one variant' });
    }

    // build FormData
    const formData = new FormData();
    formData.append("productname", productname);
    formData.append("description", description);
    formData.append("category_Id", category_Id);
    formData.append("subcategory_Id", subcategory_Id);
    formData.append("brand", brand);
    formData.append("material", material);
    formData.append("dialType", dialType);
    formData.append("variants", document.getElementById("variantData").value);


    variants.forEach((_, index) => {
      const files = variantImagesMap[index] || [];
      files.forEach(file => formData.append(`variantImages_${index}`, file));
    });

    try {
      const res = await fetch("/admin/products/add-product", { method: "POST", body: formData });
      const json = await res.json();
      if (json.success) {
        await Swal.fire({ icon: "success", text: json.message, timer: 1500, showConfirmButton: false });
        window.location.href = json.redirect1 || "/admin/products";
      } else {
        Swal.fire({ icon: "error", text: json.message || "Something went wrong" });
      }
    } catch (err) {
      console.error(err);
      Swal.fire({ icon: "error", text: "Internal server error" });
    }
  });
</script>


</html>