<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ORA Signup</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&display=swap" rel="stylesheet">
</head>

<body class="bg-gray-100 flex items-center justify-center min-h-screen">

    <!-- Outer Card Container -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden w-full max-w-4xl flex flex-col md:flex-row">

        <!-- Left: Signup Form -->
        <div class="w-full md:w-1/2 p-10 flex flex-col justify-center">
            <h1 class="text-2xl md:text-3xl font-bold mb-6 text-gray-900">Create Account</h1>

            <form id="myform" method="POST" action="/user/signup" class="flex flex-col space-y-3 " novalidate>

                <input type="text" placeholder="Full Name"
                    class="border border-gray-300 rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                    name="fullName" id="fname">

                <input type="email" placeholder="Email"
                    class="border border-gray-300 rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                    name="email" id="Email">

                <input type="text" placeholder="Mobile Number"
                    class="border border-gray-300 rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                    name="mobile" id="mobile">

                <input type="password" placeholder="Password"
                    class="border border-gray-300 rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                    name="password" id="Password">

                <input type="password" placeholder="Confirm Password"
                    class="border border-gray-300 rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                    name="Cpassword" id="Cpassword">

                <button type="button" id="toggleReferral"class="text-xs text-gray-500 hover:text-gray-700">Anyone has referred You? Claim
                    the reward <span class="text-orange-400 font-semibold">REFERRAL CODE</span></button>
                    <div id="referralBox" class="hidden mt-2">
        <input type="text"name="referralCode"placeholder="Enter referral code"
            class="border p-2 w-full"
        />
    </div>

                <button type="submit"
                    class="bg-gray-500 text-white py-2 rounded-md hover:bg-gray-800 transition mt-2">Submit</button>

            </form>


            <p class="text-sm text-gray-500 mt-4">Already have an account? <a href="/login"
                    class="text-blue-600 hover:underline">Log in</a></p>

            <div class="flex items-center my-4 text-gray-400">
                <hr class="flex-grow border-t border-gray-300">
                <span class="px-2 text-sm">Or register with</span>
                <hr class="flex-grow border-t border-gray-300">
            </div>

            <!-- Google Login -->
            <a href="/user/auth/google"
                class="flex items-center justify-center border border-gray-300 rounded-md py-2 hover:bg-gray-100 transition">
                <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google Logo"
                    class="w-5 h-5 mr-2">
                <span class="text-gray-700 font-medium">Google</span>
            </a>

        </div>

        <!-- Right: Image -->
        <div class="hidden md:flex w-1/2 items-center justify-center p-6 bg-gray-50">
            <img src="/images/login.jpeg" alt="Signup Image" class="rounded-xl shadow-lg object-cover w-full h-full">
        </div>

    </div>

</body>

</html>

<script>
    const toggleBtn = document.getElementById('toggleReferral');
const referralBox = document.getElementById('referralBox');
const referralInput = document.querySelector('input[name="referralCode"]');

// Toggle referral input box
toggleBtn.addEventListener('click', () => {
    referralBox.classList.toggle('hidden');
});

// Make referral code uppercase on input
if(referralInput){
    referralInput.addEventListener('input', e => {
        e.target.value = e.target.value.toUpperCase();
    });
}

    document.getElementById('myform').addEventListener('submit', async function (e) {
        e.preventDefault();

        const fullName = document.getElementById('fname').value.trim()
        const email = document.getElementById('Email').value.trim()
        const mobile = document.getElementById('mobile').value.trim()
        const password = document.getElementById('Password').value
        const Cpassword = document.getElementById('Cpassword').value
        //set a flag for all fields are valid
        let isValid = true;


        if (fullName === '') {
            Swal.fire({
                icon: 'error',
                text: 'Fullname required',
                timer: 2000,
                showConfirmButton: false
            })
            isValid = false;
        }
        //validate email

        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (email === '') {
            Swal.fire({
                icon: 'error',
                text: 'email required',
                timer: 2000,
                showConfirmButton: false
            })
            isValid = false;
        } else if (!emailRegex.test(email)) {
            Swal.fire({
                icon: 'error',
                text: 'Invalid email',
                timer: 2000,
                showConfirmButton: false
            })
            isValid = false;
        }

        //validate mobile
        const mobileRegex = /^[0-9]{10}$/;
        if (mobile === "") {
            Swal.fire({
                icon: 'error',
                text: 'Mobile number required',
                timer: 2000,
                showConfirmButton: false
            })
            isValid = false
        }
        else if (!mobileRegex.test(mobile)) {
            Swal.fire({
                icon: 'error',
                text: 'Invalid mobile number',
                timer: 2000,
                showConfirmButton: false
            })
            isValid = false;
        }
        //validate password
        const passwordRegex = /^(?=.*[A-Za-z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]+$/
        if (password === '') {
            Swal.fire({
                icon: 'error',
                text: 'Password required',
                timer: 2000,
                showConfirmButton: false
            })
            isValid = false
        }
        else if (!passwordRegex.test(password)) {
            Swal.fire({
                icon: 'error',
                text: 'Password should contain numbers,alphabets and special character',
                timer: 2000,
                showConfirmButton: false
            })
            isValid = false
        }
        else if (password.length < 8) {
            Swal.fire({
                icon: 'error',
                text: 'Password should contain atleast 8 characters',
                timer: 2000,
                showConfirmButton: false
            })
            isValid = false;
        }


        if (Cpassword !== password) {
            Swal.fire({
                icon: 'error',
                text: 'Password do not match',
                timer: 2000,
                showConfirmButton: false
            })
            isValid = false;
        }
        // stop if validation fails
        if (!isValid) return;


const referralCode = referralInput && referralInput.value ? referralInput.value.trim().toUpperCase() : null;
        const data = { fullName, email, mobile, password ,referralCode};

        try {
            const res = await fetch('/user/signup', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await res.json();

            if (result.success) {
                await Swal.fire({
                    icon: 'success',
                    text: result.message,
                    timer: 2000,
                    showConfirmButton: false
                })
                window.location.href = result.redirectUrl
                document.getElementById('myform').reset();
            }else {
                Swal.fire({
                    icon: 'error',
                    text: result.message,
                    timer: 2000,
                    showConfirmButton: false
                })
            }


        } catch (err) {
            console.error(err);
            Swal.fire({
                icon: 'error',
                text: 'Internal server error',
                timer: 2000,
                showConfirmButton: false
            })
        }
    });

</script>