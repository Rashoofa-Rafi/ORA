<%- include("../../partials/user/header") %>

<div class="max-w-6xl mx-auto py-10 flex gap-8">
  <!-- LEFT SIDEBAR -->
  <aside class="w-64 bg-lime-100 rounded-xl p-6 shadow">
    <div class="flex items-center gap-4 mb-6">
      <div class="w-12 h-12 rounded-full bg-black">
        <img
    src="<%= user.profileImage || '/images/default-avatar.png' %>"
    alt="Profile Image"
    class="w-full h-full object-cover"
  />
      </div>
      <p class="font-semibold"><%= user.fullName %></p>
    </div>

    <ul class="space-y-4 text-sm font-medium">
      <li><a href="/user/profile/profile" class="flex gap-2 items-center"><i data-lucide="user"></i>My Profile</a></li>
      <li><a href="/user/profile/address" class="flex gap-2 items-center font-semibold"><i data-lucide="map-pin"></i>Address</a></li>
      <li><a href="/user/profile/orders" class="flex gap-2 items-center"><i data-lucide="package"></i>My Order</a></li>
      <li><a href="/user/profile/wallet" class="flex gap-2 items-center"><i data-lucide="wallet"></i>My Wallet</a></li>
      <li><a href="/user/profile/coupons" class="flex gap-2 items-center"><i data-lucide="ticket-percent"></i>My Coupons</a></li>
      <li><a href="/user/delete-account" class="flex gap-2 items-center text-red-600"><i data-lucide="trash-2"></i>Delete Account</a></li>
      <li><a href="/user/profile/referral" class="flex gap-2 items-center"><i data-lucide="share-2"></i>Referral Code</a></li>
    </ul>
  </aside>

  <!-- RIGHT: MANAGE ADDRESS -->
  <section class="flex-1 bg-white rounded-xl shadow p-10">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-xl font-bold text-center">MANAGE ADDRESS</h2>
      <button
        id="addAddressBtn"
        class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 text-sm">
        Add new Address
      </button>
    </div>

    <!-- ADDRESS LIST -->
    <div class="space-y-4">
      <% if (addresses && addresses.length) { %>
        <% addresses.forEach(addr => { %>
          <div class="bg-gray-50 rounded-lg border px-4 py-3 flex items-start justify-between gap-4">
            <div class="text-sm">
              <p class="font-semibold uppercase">
                <%= addr.name %> 
              </p>
              <p class="text-xs mt-1 text-gray-700">
                <%= addr.addressLine %>, <%= addr.city %>, <%= addr.locality %>,<%= addr.state %> - <%= addr.pinCode %>
              </p>
              <p class="text-xs mt-1 text-gray-700">
                <%= addr.phone %>, <%= addr.altphone %>
              </p>
            </div>

            <div class="flex flex-col items-end gap-2">
              <div class="flex gap-1">
                <button
                  class="border px-3 py-1 text-xs rounded edit-address-btn"
                  data-id="<%= addr._id %>">
                  Edit
                </button>
                <button
                  class="border px-3 py-1 text-xs rounded delete-address-btn"
                  data-id="<%= addr._id %>">
                  Delete
                </button>
              </div>

              <button
                class="px-4 py-1 text-xs rounded border
                       <%= addr.isDefault ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-700' %>
                       set-default-btn"
                data-id="<%= addr._id %>">
                <%= addr.isDefault ? addr.addressType : 'Set Default' %>
              </button>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-sm text-gray-500 text-center">No addresses found. Add your first address.</p>
      <% } %>
    </div>
  </section>
</div>

<!-- ADDRESS MODAL (Add/Edit) -->
<div id="addressModal"
     class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
  <div class="bg-white rounded-lg shadow-lg w-full max-w-lg p-6 relative">
    <h2 id="modalTitle" class="text-lg font-semibold mb-4 text-center border-b pb-2">
      Add Address
    </h2>

    <form id="addressForm" class="space-y-3 text-sm">
      <input type="hidden" name="addressId" id="addressId">

      <div>
        <label class="block mb-1 font-medium">Name</label>
        <input type="text" name="name" id="name"
               class="w-full border rounded px-3 py-2" >
      </div>

      <div>
        <label class="block mb-1 font-medium">Address</label>
        <textarea name="addressLine" id="addressLine" rows="2"
                  class="w-full border rounded px-3 py-2" ></textarea>
      </div>

      <div class="grid grid-cols-3 gap-3">
        <div>
          <label class="block mb-1 font-medium">City</label>
          <input type="text" name="city" id="city"
                 class="w-full border rounded px-3 py-2" >
        </div>
        <div>
          <label class="block mb-1 font-medium">Locality</label>
          <input type="text" name="locality" id="locality"
                 class="w-full border rounded px-3 py-2" >
        </div>
        <div>
          <label class="block mb-1 font-medium">State</label>
          <input type="text" name="state" id="state"
                 class="w-full border rounded px-3 py-2" >
        </div>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div>
          <label class="block mb-1 font-medium">PinCode</label>
          <input type="text" name="pinCode" id="pinCode"
                 class="w-full border rounded px-3 py-2" >
        </div>
        <div>
          <label class="block mb-1 font-medium">Phone</label>
          <input type="text" name="phone" id="phone"
                 class="w-full border rounded px-3 py-2" >
        </div>
        <div>
          <label class="block mb-1 font-medium">AlternatePhone</label>
          <input type="text" name="altPhone" id="altPhone"
                 class="w-full border rounded px-3 py-2" >
        </div>
      </div>

      <div>
        <label class="block mb-1 font-medium">Type</label>
        <select name="addressType" id="type" class="w-full border rounded px-3 py-2">
          <option value="Home">Home</option>
          <option value="Work">Work</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div class="flex items-center gap-2 mt-2">
        <input type="checkbox" id="isDefault" name="isDefault" class="h-4 w-4">
        <label for="isDefault" class="text-sm">Set as default address</label>
      </div>

      <div class="flex justify-end gap-3 mt-4">
        <button type="button" id="cancelModalBtn" class="px-4 py-2 border rounded">Cancel</button>
        <button type="submit" class="px-4 py-2 bg-black text-white rounded">Save</button>
     </div>
    </form>
  </div>
</div>

<script>
  lucide.createIcons();

  const addAddressBtn  = document.getElementById('addAddressBtn');
  const addressModal   = document.getElementById('addressModal');
  const addressForm    = document.getElementById('addressForm');
  const modalTitle     = document.getElementById('modalTitle');
  const cancelModalBtn = document.getElementById('cancelModalBtn');
  const addressError   = document.getElementById('addressError');

  const idInput        = document.getElementById('addressId');
  const nameInput      = document.getElementById('name');
  const addrInput      = document.getElementById('addressLine');
  const cityInput      = document.getElementById('city');
  const localityInput  = document.getElementById('locality')
  const stateInput     = document.getElementById('state');
  const pinCodeInput   = document.getElementById('pinCode');
  const phoneInput     = document.getElementById('phone')
  const altPhoneInput     = document.getElementById('altPhone')
  const addressTypeInput      = document.getElementById('type');
  const isDefaultInput = document.getElementById('isDefault');

  function openModal(mode, data) {
    addressForm.reset();
    if (mode === 'add') {
      modalTitle.textContent = 'Add Address';
      idInput.value = '';
    } else {
      modalTitle.textContent = 'Edit Address';
      idInput.value      = data._id;
      nameInput.value    = data.name;
      addrInput.value    = data.addressLine;
      cityInput.value    = data.city;
      localityInput.value   = data.locality
      stateInput.value   = data.state;
      pinCodeInput.value = data.pinCode;
      phoneInput.value   = data.phone
      altPhoneInput.value   = data.altPhone
      addressTypeInput.value    = data.addressType || 'Home';
      isDefaultInput.checked = !!data.isDefault;
    }
    addressModal.classList.remove('hidden');
  }

  function closeModal() {
    addressModal.classList.add('hidden');
  }

  addAddressBtn.addEventListener('click', () => openModal('add'));

  cancelModalBtn.addEventListener('click', closeModal)

// Handle Add/Edit submit
function isValidPincode(pin) {
  return /^[1-9][0-9]{5}$/.test(pin);
}

function isValidPhone(phone) {
  return /^[6-9][0-9]{9}$/.test(phone);
}


  addressForm.addEventListener('submit', async (e) => {
    e.preventDefault()
    const  data = {
     name       :nameInput.value.trim(),
     addressLine:addrInput.value.trim(),
     city       :cityInput.value.trim(),
     locality   :localityInput.value.trim(),
     state      :stateInput.value.trim(),
     pinCode    :pinCodeInput.value.trim(),
     phone      :phoneInput.value.trim(),
     altPhone   :altPhoneInput.value.trim(),
     addressType:addressTypeInput.value,
     isDefault  :isDefaultInput.checked

    }
    // PINCODE
  if (!isValidPincode(data.pinCode)) {
    return Swal.fire({
      icon: 'error',
      title: 'Invalid Pincode',
      text: 'Pincode must be 6 digits '
    });
  }

  // PHONE
  if (!isValidPhone(data.phone)) {
    return Swal.fire({
      icon: 'error',
      title: 'Invalid Phone Number',
      text: 'Phone number must be 10 digits '
    });
  }

  if(data.altPhone===data.phone){
      return Swal.fire({
      icon: 'error',
      title: 'Invalid Alternate Phone',
      text: 'Alternate phone must be different'
    })
    }

    const id = idInput.value;
    const url = id ? `/user/profile/address/${id}` : '/user/profile/address'
    const method = id ? 'PUT' : 'POST';

    try {
      const res = await fetch(url, {
        method,
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      const result = await res.json();

      if (result.success) {
        await Swal.fire({
            icon:'success',
            title:result.message,
            timer:1500
        })
        closeModal();
        location.reload();
      } else {
        Swal.fire({
            icon:'error',
            text:result.message,
            timer:1500
        })
      }
    } catch (err) {
      console.error(err)
             Swal.fire({
                icon: 'error',
                text: 'Internal server error',
                timer:2000,
                showConfirmButton: false,
    })
  }
})

  document.querySelectorAll('.edit-address-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const id = btn.dataset.id;

    try {
      const res = await fetch(`/user/profile/address/${id}`, {
        method: 'GET',
        credentials: 'include'
      });
      const result = await res.json();

      if (result.success && result.address) {
        openModal('edit', result.address);
      } else {
        Swal.fire({
          icon: 'error',
          text: result.message || 'Failed to load address'
        });
      }
    } catch (err) {
      Swal.fire({
        icon: 'error',
        text: 'Error loading address'
      });
    }
  });
});
 

document.querySelectorAll('.delete-address-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      const confirm = await Swal.fire({
        icon: 'warning',
        text: 'Delete this address?',
        showCancelButton: true,
        confirmButtonText: 'Delete'
      });
      if (!confirm.isConfirmed) return

      const res = await fetch(`/user/profile/address/${id}`, {
        method: 'DELETE',
        credentials: 'include'
      });
      const result = await res.json();
      if (result.success) {
        await Swal.fire({
            icon:'success',
            text:result.message,
            timer:2000
        })
        location.reload();
      } else {
        Swal.fire({
             icon: 'error',
              text: result.message
             });
      }
    });
  });

  document.querySelectorAll('.set-default-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const id = btn.dataset.id;

    try {
      const res = await fetch(`/user/profile/address/${id}/default`, {
        method: 'POST',
        credentials: 'include'
      });
      const result = await res.json();

      if (result.success) {
        await Swal.fire({
          icon: 'success',
          text: result.message,
          timer: 1500,
          showConfirmButton: false
        });
        location.reload()
      } else {
        Swal.fire({
          icon: 'error',
          text: result.message,
        });
      }
    } catch (err) {
      Swal.fire({
        icon: 'error',
        text: 'Failed to update default address'
      });
    }
  });
});


</script>
  
<%- include("../../partials/user/footer") %>