<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#F5F5F5] flex items-center justify-center min-h-screen">

  <div class="bg-white rounded-3xl shadow-lg flex flex-col md:flex-row items-center w-full max-w-4xl overflow-hidden">
    <!-- Left Section -->
    <div class="w-full md:w-1/2 p-10 text-center md:text-left">
      <h1 class="text-2xl font-extrabold text-black mb-4">Forgot Password ?</h1>
      <p class="text-gray-600 text-sm mb-6">Please enter your mail address</p>

      <form class="flex flex-col gap-4" id="myform">
        <input type="email" name="email" placeholder="Email address" id="email"
          class="w-full border border-gray-300 rounded-md px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-400">
        <div id="errMsg" class="text-red-500 text-sm"></div>
        <button
          type="submit"
          class="bg-gray-800 text-white font-semibold py-2 rounded-md hover:bg-black transition duration-200">
          Send OTP
        </button>
        <div id="successMsg" class="text-green-600 text-sm"></div>
        <a href="/user/login" class="text-gray-500 text-sm hover:underline">Go back to Login page</a>
      </form>
    </div>

    <!-- Right Section (Image) -->
    <div class="w-full md:w-1/2">
      <img src="/images/login.jpeg"
        alt="Jewelry" class="w-full h-full object-cover">
    </div>
  </div>

</body>

</html>
<script>

  document.getElementById('myform').addEventListener('submit',async(e)=>{
    e.preventDefault()

    let email=document.getElementById('email').value.trim()

    let isvalid=true

    let emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/
    if(email===''){
      document.getElementById('errMsg').textContent='please enter your registered email'
      isvalid=false
    }else if(!emailRegex.test(email)){
      document.getElementById('errMsg').textContent='invalid email'
      isvalid=false
    }
    if(!isvalid)
      return 
    
    try {
       const res= await fetch ('/user/forgetPassword',{
        method:"POST",
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({email})
       })

       const result= await res.json()
        if(result.success){
          document.getElementById('successMsg').textContent=result.message
          window.location.href=result.redirectUrl
        }else{
        document.getElementById('successMsg').textContent=result.message
        }
       
    } catch (error) {
      console.error(error)
      document.getElementById('successMsg').textContent='server error'
      
    }
    

  })
</script>
