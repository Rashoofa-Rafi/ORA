<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CheckoutPage</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script>
    const RAZORPAY_KEY_ID = "<%= process.env.RAZORPAY_KEY_ID %>";
  </script>
  <script src="/js/placeOrder.js"></script>
</head>

<body class="bg-gray-50">
  <%- include("../partials/user/header") %>
    <div class="container mx-auto px-6 py-10">
      <h2 class="text-2xl font-semibold text-center mb-10">
        PLACE YOUR ORDER
      </h2>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- LEFT SIDE -->
        <form id="placeOrderForm" class="lg:col-span-2">

          <!-- Delivered To -->
          <div class="mb-8">
            <h3 class="font-semibold mb-2">Delivered To</h3>
            <p class="font-medium">
              <%= address.name %>
            </p>
            <p class="text-sm text-gray-600">
              <%= address.addressLine %>, <%= address.city %>,
                  <%= address.state %> - <%= address.pinCode %>
            </p>
          </div>

          <!-- Payment Methods -->
          <div class="space-y-4">
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="radio" onclick="openRazorpay()" name="paymentMethod" value="RAZORPAY" required />
              <div>
                <p class="font-medium">Razorpay</p>
                <p class="text-sm text-gray-500">Pay using Razorpay</p>
              </div>
            </label>


            <label class="flex items-start gap-3 cursor-pointer">
              <input type="radio" name="paymentMethod" value="WALLET" />
              <div>
                <p class="font-medium">Wallets</p>
                <p class="text-sm text-gray-500">Use your wallet balance</p>
              </div>
            </label>

            <label class="flex items-start gap-3 cursor-pointer">
              <input type="radio" name="paymentMethod" value="COD" />
              <p class="font-medium">Cash on Delivery</p>
            </label>
          </div>

        </form>

        <!-- RIGHT SIDE -->
        <div class="bg-gray-100 rounded-lg p-6 h-fit">

          <h3 class="font-semibold mb-4">Order Summary</h3>

          <% cartItems.forEach(item=> { %>
            <div class="flex justify-between text-sm mb-2">
              <span>
                <%= item.quantity %> × <%= item.productId.productname %>
              </span>
              <span>₹<%= item.quantity * item.variantId.price %></span>
            </div>
            <% }) %>

              <hr class="my-3">


              <div class="flex justify-between text-sm">
                <span>Total Items</span>
                <span>
                  <%= summary.totalItems %>
                </span>
              </div>

              <div class="flex justify-between text-sm">
                <span>OriginalPrice</span>
                <span>₹<%= summary.originalTotal %></span>
              </div>
              <% if (summary.offerDiscount> 0) { %>
                <div class="flex justify-between text-sm text-green-600">
                  <span>OfferDiscount</span>
                  <span>-₹<%= summary.offerDiscount %></span>
                </div>
                <% } %>
                  <div class="flex justify-between text-sm">
                    <span>DiscountedPrice</span>
                    <span>₹<%= summary.discountedTotal %></span>
                  </div>

                  <div class="flex justify-between text-sm">
                    <span>Delivery Charges</span>
                    <span class="text-green-600">
                      <%=summary.deliveryCharge%>
                    </span>
                  </div>

                  <div class="flex justify-between text-sm">
                    <span>Platform Fee</span>
                    <span>₹<%= summary.platformFee %></span>
                  </div>



                  <% if (appliedCoupon) { %>
                    <div class="flex justify-between text-sm text-green-600">
                      <span>
                        Coupon (<%= appliedCoupon.code %>)
                      </span>
                      <span>-₹<%= summary.couponDiscount %></span>
                    </div>
                    <% } %>

                      <hr class="my-3">

                      <div class="flex justify-between font-semibold text-lg mb-4">
                        <span>Total</span>
                        <span>₹<%= summary.finalAmount %></span>
                      </div>

                      <!-- Submit button linked to form -->
                      <button id="placeOrderBtn" class="w-full bg-black text-white py-3 rounded">Place Order</button>
        </div>

      </div>


    </div>
    <%- include("../partials/user/footer") %>
    
      <script>
        const finalAmount = <%= summary && summary.finalAmount ? summary.finalAmount : 0 %>;
        document.getElementById("placeOrderBtn").addEventListener("click", async () => {
          const paymentMethod = document.querySelector(
            'input[name="paymentMethod"]:checked'
          )?.value;

          if (!paymentMethod) {
            return Swal.fire({
              icon: 'error',
              title: 'Select a payment method'
            });
          }
          if (paymentMethod === "COD" && finalAmount > 1000) {
    return Swal.fire({
      icon: 'error',
      title: 'COD not available',
      text: 'Cash on Delivery is allowed only for orders up to ₹1000.'
    });
  }

          try {
            const res = await fetch("/user/payment/place-order", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ paymentMethod })
            });

            const data = await res.json();

            if (!res.ok || !data.success) {
              return Swal.fire({
                icon: 'error',
                title: data.message || 'Order failed'
              });
            }

            // ✅ COD → DIRECT REDIRECT
            if (paymentMethod === "COD") {
              return window.location.href = `/user/order-success/${data.orderId}`;
            }
            if (paymentMethod === "WALLET") {
              return window.location.href = `/user/order-success/${data.orderId}`;
            }

            // ✅ RAZORPAY → OPEN GATEWAY
            if (paymentMethod === "RAZORPAY") {
              openRazorpay({
                razorpayOrderId: data.razorpayOrderId,
                amount: data.amount,
                orderId: data.orderId
              });
            }


          } catch (err) {
            Swal.fire({
              icon: 'error',
              title: 'Internal server error'
            });
          }
        });

        function openRazorpay({ razorpayOrderId, amount, orderId }) {
          const options = {
            key: "<%= process.env.RAZORPAY_KEY_ID %>",
            amount: Math.round(amount * 100),
            currency: "INR",
            name: "ORA Store",
            order_id: razorpayOrderId,
            handler: async function (response) {
              await verifyPayment({ ...response, orderId });
            },

            modal: {
              ondismiss: async function () {
                await fetch(`/user/profile/orders/${orderId}/payment-failed`, {
                  method: 'POST'
                });
                Swal.fire({
                  icon: 'info',
                  title: 'Payment not completed',
                  text: 'You can Retry payment from  orders page?',
                  timer: 4000,
                  confirmButtonText: 'View Orders',
                  allowOutsideClick: false
                }).then(() => {
                  window.location.href = '/user/profile/orders';
                });

              }
            },

            theme: { color: "#3399cc" }
          };

          const rzp = new Razorpay(options)
          rzp.on('payment.failed', async function (response) {
            await fetch(`/user/profile/orders/${orderId}/payment-failed`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                razorpay_order_id: response.error.metadata.order_id,
                razorpay_payment_id: response.error.metadata.payment_id,
                reason: response.error.reason
              })
            });

            Swal.fire({
              icon: 'error',
              title: 'Payment Failed',
              text: 'You can retry payment from Orders page',
              confirmButtonText: 'View Orders',
              allowOutsideClick: false
            }).then(() => {
              window.location.href = '/user/profile/orders';
            });
          });

          rzp.open();
        };


        async function verifyPayment(payload) {
          try {
            const res = await fetch('/user/payment/verify', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });

            const data = await res.json();

            if (!res.ok || !data.success) {
              await fetch(`/user/profile/orders/${payload.orderId}/payment-failed`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
              });
              await Swal.fire({
                icon: 'error',
                title: 'Payment Failed',
                text: 'You can retry payment from Orders page',
                confirmButtonText: 'View Orders',
                allowOutsideClick: false
              })
              return window.location.href = '/user/profile/orders';


            }

            // ✅ Success
            window.location.href = `/user/order-success/${data.orderId}`;

          } catch (err) {
            Swal.fire('Error', 'Something went wrong', 'error');
          }
        }
      

      </script>



</body>