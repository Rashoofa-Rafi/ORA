<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CheckoutPage</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-50">
  <%- include("../partials/user/header") %>
    <div class="container mx-auto px-4 py-8">
      <h2 class="text-2xl font-semibold text-center mb-8">
        Select Your Delivery Address
      </h2>

      <form action="/user/checkout" method="POST">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

          <!-- LEFT: Addresses -->
          <div class="md:col-span-2 space-y-4">
            <% if (addresses.length===0) { %>
              <p class="text-red-500">No address found. Please add one.</p>
              <% } %>

                <% addresses.forEach(address=> { %>
                  <label class="block border rounded p-4 cursor-pointer hover:border-lime-900">
                    <input type="radio" name="addressId" value="<%= address._id %>" class="mr-2" <%=address.isDefault
                      ? 'checked' : '' %>
                    required
                    />

                    <div class="inline-block align-top">
                      <p class="font-medium">
                        <%= address.name %>
                      </p>
                      <p class="text-sm text-gray-600">
                        <%= address.house %>, <%= address.city %>,
                            <%= address.state %> - <%= address.pincode %>
                      </p>

                      <button type="button" class="text-sm text-blue-600 mt-1 inline-block edit-address-btn"
                        data-id="<%= address._id %>">Edit</button>
                    </div>
                  </label>
                  <% }) %>

                    <button type="button" class="inline-block mt-3 text-lime-900 font-medium" id="addAddressBtn">+ Add
                      New Address</button>
          </div>



          <!-- RIGHT: Order Summary -->
          <div class="bg-white shadow rounded p-6 h-fit">
            <h3 class="text-lg font-semibold mb-4">Order Summary</h3>

            <% cartItems.forEach(item=> { %>
              <div class="flex justify-between text-sm mb-2">
                <span>
                  <%= item.quantity %> × <%= item.productId.productname %>
                </span>
                <span>
                  ₹<%= item.quantity * item.finalPrice %>
                </span>
              </div>
              <% }) %>

                <hr class="my-3">

                <div class="flex justify-between text-sm">
                  <span>Total Items</span>
                  <span>
                    <%= summary.totalItems %>
                  </span>
                </div>

                <div class="flex justify-between text-sm">
                  <span>OriginalPrice</span>
                  <span>₹<%= summary.originalTotal %></span>
                </div>
                <% if (summary.offerDiscount> 0) { %>
                  <div class="flex justify-between text-sm text-green-600">
                    <span>OfferDiscount</span>
                    <span>-₹<%= summary.offerDiscount %></span>
                  </div>
                  <% } %>
                <div class="flex justify-between text-sm">
                  <span>DiscountedPrice</span>
                  <span>₹<%= summary.discountedTotal %></span>
                </div>


                <div class="flex justify-between text-sm">
                  <span>Delivery Charges</span>
                  <span>₹<%= summary.deliveryCharge %></span>
                </div>

                <div class="flex justify-between text-sm">
                  <span>Platform Fee</span>
                  <span>₹<%= summary.platformFee %></span>
                </div>

                

                    <% if (summary.couponDiscount> 0) { %>
                      <div class="flex justify-between text-sm text-green-600">
                        <span>Coupon Discount</span>
                        <span>-₹<%= summary.couponDiscount %></span>
                      </div>
                      <% } %>

                        <hr class="my-3">

                        <div class="flex justify-between font-bold text-lg">
                          <span>Total Payable</span>
                          <span>₹<%= summary.finalAmount %></span>
                        </div>

                        <div class="mt-4">
                          <% if (!appliedCoupon) { %>
                            <div class="flex gap-2">
                              <input type="text" id="couponCode" placeholder="Enter coupon code"class="border px-3 py-2 rounded w-full text-sm" />
                              <button type="button" onclick="applyCoupon()" class="bg-red-600 text-white px-4 rounded text-sm">
                              Apply
                              </button>
                              <button type="button"onclick="openCouponModal()"class="text-green-400 text-sm">
                               Available Coupons?</button>

                            </div>
                            <% } else { %>
                              <div
                                class="flex justify-between items-center bg-green-50 border border-green-400 text-green-700 px-3 py-2 rounded text-sm">
                                <span>Coupon "<strong>
                                    <%= appliedCoupon.code %>
                                  </strong>" applied</span>
                                <button type="button" onclick="removeCoupon()" class="text-red-600 text-xs underline">
                                  Remove
                                </button>
                              </div>
                              <% } %>
                        </div>

                        <button type="submit"
                          class="w-full mt-5 bg-gray-900 text-white py-3 rounded hover:bg-lime-700">Continue</button>
          </div>

        </div>
      </form>
    </div>
    <div id="addressModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
      <div class="bg-white rounded-lg shadow-lg w-full max-w-lg p-6 relative">
        <h2 id="modalTitle" class="text-lg font-semibold mb-4 text-center border-b pb-2">
          Add Address
        </h2>

        <form id="addressForm" class="space-y-3 text-sm">
          <input type="hidden" name="addressId" id="addressId">

          <div>
            <label class="block mb-1 font-medium">Name</label>
            <input type="text" name="name" id="name" class="w-full border rounded px-3 py-2" >
          </div>

          <div>
            <label class="block mb-1 font-medium">Address</label>
            <textarea name="addressLine" id="addressLine" rows="2" class="w-full border rounded px-3 py-2"
              ></textarea>
          </div>

          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="block mb-1 font-medium">City</label>
              <input type="text" name="city" id="city" class="w-full border rounded px-3 py-2" >
            </div>
            <div>
              <label class="block mb-1 font-medium">Locality</label>
              <input type="text" name="locality" id="locality" class="w-full border rounded px-3 py-2" >
            </div>
            <div>
              <label class="block mb-1 font-medium">State</label>
              <input type="text" name="state" id="state" class="w-full border rounded px-3 py-2" >
            </div>
          </div>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="block mb-1 font-medium">PinCode</label>
              <input type="text" name="pinCode" id="pinCode" class="w-full border rounded px-3 py-2" >
            </div>
            <div>
              <label class="block mb-1 font-medium">Phone</label>
              <input type="text" name="phone" id="phone" class="w-full border rounded px-3 py-2" >
            </div>
            <div>
              <label class="block mb-1 font-medium">AlternatePhone</label>
              <input type="text" name="altPhone" id="altPhone" class="w-full border rounded px-3 py-2" >
            </div>
          </div>

          <div>
            <label class="block mb-1 font-medium">Type</label>
            <select name="addressType" id="type" class="w-full border rounded px-3 py-2">
              <option value="Home">Home</option>
              <option value="Work">Work</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="flex items-center gap-2 mt-2">
            <input type="checkbox" id="isDefault" name="isDefault" class="h-4 w-4">
            <label for="isDefault" class="text-sm">Set as default address</label>
          </div>

          <div class="flex justify-end gap-3 mt-4">
            <button type="button" id="cancelModalBtn" class="px-4 py-2 border rounded">Cancel</button>
            <button type="submit" class="px-4 py-2 bg-black text-white rounded">Save</button>
          </div>
        </form>
      </div>
    </div>
    <div id="couponModal"
     class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">

  <div class="bg-white w-full max-w-md rounded-lg p-6 relative">

    <h2 class="text-lg font-semibold mb-4">Available Coupons</h2>

    <div id="couponList" class="space-y-2 max-h-60 overflow-y-auto">
      <!-- Coupons will load here -->
    </div>

    <button onclick="closeCouponModal()"
            class="mt-4 w-full bg-gray-200 py-2 rounded">
      Close
    </button>

  </div>
</div>


    <%- include("../partials/user/footer") %>
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const addAddressBtn = document.getElementById('addAddressBtn');
          const addressModal = document.getElementById('addressModal');
          const addressForm = document.getElementById('addressForm');
          const modalTitle = document.getElementById('modalTitle');
          const cancelModalBtn = document.getElementById('cancelModalBtn');


          const idInput = document.getElementById('addressId');
          const nameInput = document.getElementById('name');
          const addrInput = document.getElementById('addressLine');
          const cityInput = document.getElementById('city');
          const localityInput = document.getElementById('locality')
          const stateInput = document.getElementById('state');
          const pinCodeInput = document.getElementById('pinCode');
          const phoneInput = document.getElementById('phone')
          const altPhoneInput = document.getElementById('altPhone')
          const addressTypeInput = document.getElementById('type');
          const isDefaultInput = document.getElementById('isDefault');

          function openModal(mode, data) {
            addressForm.reset();
            if (mode === 'add') {
              modalTitle.textContent = 'Add Address';
              idInput.value = '';
            } else {
              modalTitle.textContent = 'Edit Address';
              idInput.value = data._id;
              nameInput.value = data.name;
              addrInput.value = data.addressLine;
              cityInput.value = data.city;
              localityInput.value = data.locality
              stateInput.value = data.state;
              pinCodeInput.value = data.pinCode;
              phoneInput.value = data.phone
              altPhoneInput.value = data.altPhone
              addressTypeInput.value = data.addressType || 'Home';
              isDefaultInput.checked = !!data.isDefault;
            }
            addressModal.classList.remove('hidden');
          }

          function closeModal() {
            addressModal.classList.add('hidden');
          }

          if (addAddressBtn) {
            addAddressBtn.addEventListener('click', () => openModal('add'));
          }

          if (cancelModalBtn) {
            cancelModalBtn.addEventListener('click', closeModal);
          }
          // Handle Add/Edit submit
          function isValidPincode(pin) {
            return /^[1-9][0-9]{5}$/.test(pin);
          }

          function isValidPhone(phone) {
            return /^[6-9][0-9]{9}$/.test(phone);
          }
          addressForm.addEventListener('submit', async (e) => {

            e.preventDefault()
            const data = {
              name: nameInput.value.trim(),
              addressLine: addrInput.value.trim(),
              city: cityInput.value.trim(),
              locality: localityInput.value.trim(),
              state: stateInput.value.trim(),
              pinCode: pinCodeInput.value.trim(),
              phone: phoneInput.value.trim(),
              altPhone: altPhoneInput.value.trim(),
              addressType: addressTypeInput.value,
              isDefault: isDefaultInput.checked

            }
            if (!isValidPincode(data.pinCode)) {
              return Swal.fire({
                icon: 'error',
                title: 'Invalid Pincode',
                text: 'Pincode must be 6 digits '
              });
            }

            // PHONE
            if (!isValidPhone(data.phone)) {
              return Swal.fire({
                icon: 'error',
                title: 'Invalid Phone Number',
                text: 'Phone number must be 10 digits '
              });
            }

            if (data.altPhone === data.phone) {
              return Swal.fire({
                icon: 'error',
                title: 'Invalid Alternate Phone',
                text: 'Alternate phone must be different'
              })
            }

            const id = idInput.value;
            const url = id ? `/user/profile/address/${id}` : '/user/profile/address'
            const method = id ? 'PUT' : 'POST';

            try {
              const res = await fetch(url, {
                method,
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
              })
              const result = await res.json();

              if (result.success) {
                await Swal.fire({
                  icon: 'success',
                  title: result.message,
                  timer: 1500
                })
                closeModal();
                location.reload();
              } else {
                Swal.fire({
                  icon: 'error',
                  text: result.message,
                  timer: 1500
                })
              }
            } catch (err) {
              console.error(err)
              Swal.fire({
                icon: 'error',
                text: 'Internal server error',
                timer: 2000,
                showConfirmButton: false,
              })
            }
          })

          document.querySelectorAll('.edit-address-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
              const id = btn.dataset.id;

              try {
                const res = await fetch(`/user/profile/address/${id}`, {
                  method: 'GET',
                  credentials: 'include'
                });
                const result = await res.json();

                if (result.success && result.address) {
                  openModal('edit', result.address);
                } else {
                  Swal.fire({
                    icon: 'error',
                    text: result.message || 'Failed to load address'
                  });
                }
              } catch (err) {
                Swal.fire({
                  icon: 'error',
                  text: 'Error loading address'
                });
              }
            });
          });

        })
        async function applyCoupon() {
  const code = document.getElementById('couponCode').value.trim()

  if (!code) return

  const res = await fetch('/user/coupons/apply', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ code })
  })

  const data = await res.json()

  if (!res.ok) {
    return Swal.fire({ icon: 'error', title: data.message })
  }

  location.reload()
}
async function removeCoupon() {
  await fetch('/user/coupons/remove', { method: 'DELETE' })
  location.reload()
}
async function openCouponModal() {
  const modal = document.getElementById("couponModal");
  const list = document.getElementById("couponList");

  try {
    const res = await fetch("/user/checkout/coupons");
    const data = await res.json();

    if (!data.success) return;

    list.innerHTML = "";

    if (data.coupons.length === 0) {
      list.innerHTML = "<p class='text-sm text-gray-500'>No coupons available</p>";
    }

    data.coupons.forEach(coupon => {
      const div = document.createElement("div");
      div.className = "border p-2 rounded flex justify-between items-center";

      div.innerHTML = `
        <div>
          <p class="font-semibold">${coupon.code}</p>
          <p class="text-xs text-gray-500">minOrderPrice:${coupon.minOrderPrice || ""}</p>
          <p class="text-xs text-gray-500">DiscountType:${coupon.discountType || ""}</p>
          <p class="text-xs text-gray-500">DiscountValue:${coupon.discountValue|| ""}</p>
          <p class="text-xs text-gray-500">UsageLimit:${coupon.usageLimit || ""}</p>
        </div>
        <button onclick="selectCoupon('${coupon.code}')"
                class="bg-red-600 text-white px-2 py-1 rounded text-xs">
          Use
        </button>
      `;

      list.appendChild(div);
    });

    modal.classList.remove("hidden");

  } catch (err) {
    alert("Failed to load coupons");
  }
}

function closeCouponModal() {
  document.getElementById("couponModal").classList.add("hidden");
}

function selectCoupon(code) {
  document.getElementById("couponCode").value = code;
  closeCouponModal();
}
      </script>
</body>