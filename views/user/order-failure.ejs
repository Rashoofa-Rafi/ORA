<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order-failure</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-50">
    <%- include("../partials/user/header") %>
    <div class="container mx-auto px-6 py-16">

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- LEFT SIDE -->
    <div class="text-center lg:text-left">

      <div class="flex justify-center lg:justify-start mb-6">
          <div class="w-20 h-20 bg-red-500 rounded-full flex items-center justify-center">
            <!-- ❌ Payment failure icon -->
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="3"
                 viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M6 18L18 6M6 6l12 12" />
            </svg>
          </div>
        </div>

        <h1 class="text-2xl font-semibold mb-6 text-red-700">
          PAYMENT FAILED
        </h1>

        <p class="text-gray-600 mb-6">
          Your payment could not be processed. Please try again or check your order details.
        </p>


      <div class="flex gap-4 justify-center lg:justify-start">
        <a href="/user/profile/orders"
           class="border border-gray-400 px-6 py-2 rounded hover:bg-gray-100">
          View Orders
        </a>

        <a href="/user/payment/<%= order._id %>"
           class="border border-gray-400 px-6 py-2 rounded hover:bg-gray-100">
          Retry Payment
        </a>
      </div>

    </div>

    


    <%- include("../partials/user/footer") %>
</body>