<%- include("../partials/user/header") %>
    <!-- Breadcrumb -->
    <div class="w-full bg-gray-50 py-3 px-6 text-sm text-gray-600">
        <div class="max-w-6xl mx-auto flex gap-2 items-center flex-wrap">

            <% breadcrumb.forEach((b, index)=> { %>

                <% if (b.url) { %>
                    <a href="<%= b.url %>" class="hover:text-black hover:underline">
                        <%= b.name %>
                    </a>
                    <% } else { %>
                        <span class="text-black font-semibold">
                            <%= b.name %>
                        </span>
                        <% } %>

                            <% if (index < breadcrumb.length - 1) { %>
                                <span>/</span>
                                <% } %>

                                    <% }) %>

        </div>
    </div>


    <div class="container mx-auto px-4 py-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

            <!-- LEFT SIDE IMAGES -->
            <div class="flex gap-6">
                <div class="flex flex-col gap-4 w-28">
                    <% product.activeVariant.images.forEach((img, index)=> { %>
                        <img onclick="changeMainImage('<%= img %>')" src="<%= img %>" class="w-28 h-28 object-cover rounded-lg cursor-pointer border 
                 <%= index === 0 ? 'border-black' : 'border-gray-300' %>
                 hover:border-black transition" />
                        <% }) %>

                </div>

                <!-- Main Image -->
                <div id="imageZoomContainer"
                    class="flex-1 bg-gray-100 rounded-lg p-3 overflow-hidden relative cursor-zoom-in">
                    <img id="mainImage" src="<%= product.activeVariant.images[0] %>"
                        class="w-full max-h-[600px] object-contain transition-transform duration-200" />
                </div>

            </div>

            <!-- RIGHT SIDE INFO -->
            <div class="text-center flex flex-col items-center">
                <h2 class="text-2xl font-semibold text-gray-900 mb-1">
                    <%= product.name %>
                </h2>
                <p class="text-gray-500 text-sm mb-4">Premium Watches</p>
                <!-- PRICE & OFFER -->
<div class="text-center flex flex-col items-center gap-2">

  <% if (product.activeOffer) { %>
    <!-- Show discounted price -->
    <div class="text-green-600 font-bold text-2xl flex items-center gap-3">
      ₹ <%= product.activeVariant.price.toFixed(2) %>
      <span class="text-gray-400 line-through text-lg">
        ₹ <%= product.activeOffer.originalPrice.toFixed(2) %>
      </span>
      <span class="text-xs px-2 py-1 bg-orange-100 text-orange-600 rounded">
        <%= product.activeOffer.percentage %>% OFF
      </span>
    </div>
  <% } else { %>
    <!-- No offer -->
    <div class="text-green-600 font-bold text-2xl">
      ₹ <%= product.activeVariant.price.toFixed(2) %>
    </div>
  <% } %>

</div>


                <!-- <div class="mt-3 flex gap-2 justify-center">
                    ⭐⭐⭐⭐⭐
                    <span class="text-gray-500 text-sm">4.6</span>
                </div> -->

                <!-- COLOR SELECTION -->
                <div class="mt-5">
                    <label class="font-medium text-gray-700 text-sm">Available Colors:</label>
                    <div class="flex gap-2 mt-3 justify-center">
                        <% product.variants.forEach(v=> { %>
                            <a href="/user/product-details/<%= product.id %>?variant=<%= v.id %>" class="block rounded-md border overflow-hidden
                  <%= product.activeVariant.id === v.id ? 'border-black' : 'border-gray-300' %>">

                                <img src="<%= v.images[0] %>"
                                    class="w-12 h-12 object-cover hover:scale-105 transition" />
                            </a>
                            <% }) %>

                    </div>
                </div>


                <!-- STOCK INFO -->
                <p class="mt-3 text-sm font-semibold items-center">
                    Stock Available: <%= product.activeVariant.stock %>
                </p>

                <!-- BUTTONS -->
                <div class="mt-6 space-y-3 flex flex-col items-center">

                    <button onclick=" addToWishlist('<%= product.id %>','<%= product.activeVariant.id %>')"
                    class="w-1/2 min-w-[200px] py-2 rounded-md bg-red-600 text-white border border-gray-900 font-semibold 
                hover:bg-red-700 hover:text-white transition">ADD TO WISHLIST
                    </button>

                    <button onclick="addToCart('<%= product.id %>','<%= product.activeVariant.id %>')"
                      class="w-1/2 min-w-[200px] py-2 rounded-md bg-black text-white font-semibold hover:bg-gray-900 transition">
                        ADD TO CART
                    </button>

                </div>

                <!-- DESCRIPTION -->
                <div class="mt-10">
                    <div class="flex gap-6 border-b pb-2 text-sm font-semibold">
                        <button class="text-black border-b-2 border-black pb-2">DESCRIPTION</button>
                        <button class="text-gray-500 hover:text-black">REVIEW</button>
                    </div>

                    <div class="text-sm text-gray-700 leading-6 mt-6 space-y-1">
                        <p>
                            <%= product.description %>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- RELATED PRODUCTS SECTION -->
    <div class="mt-16">
        <h2 class="text-2xl font-semibold mb-6">Related Products</h2>

        <% if (relatedProducts && relatedProducts.length> 0) { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">

                <% relatedProducts.forEach(rp=> { %>
                    <a href="/user/product-details/<%= rp._id %>"
                        class="block border rounded-lg shadow hover:shadow-lg transition">

                        <!-- IMAGE -->
                        <div class="h-48 overflow-hidden rounded-t-lg bg-gray-100 flex items-center justify-center">
                            <% if (rp.variants && rp.variants[0] && rp.variants[0].images && rp.variants[0].images[0]) {
                                %>
                                <img src="<%= rp.variants[0].images[0] %>" alt="Product Image"
                                    class="w-full h-full object-cover">
                                <% } else { %>
                                    <div class="text-gray-400 text-center">No Image</div>
                                    <% } %>
                        </div>

                        <!-- DETAILS -->
                        <div class="p-4">
                            <p class="font-semibold text-lg">
                                <%= rp.productname %>
                            </p>

                            <% if (rp.variants && rp.variants[0]) { %>
                                <p class="text-gray-700 font-medium">
                                    ₹<%= rp.variants[0].price %>
                                </p>
                                <% } %>
                        </div>

                    </a>
                    <% }) %>

            </div>
            <% } else { %>
                <p class="text-gray-500">No related products available.</p>
                <% } %>
    </div>



    <script>
  async function addToCart(productId,variantId) {
    
  try {
    const res = await fetch(`/user/cart/add`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ productId ,variantId})
    });

    const data = await res.json();

    if (res.ok) {
        const cartBadge = document.getElementById('cart-count');
      if (cartBadge) cartBadge.textContent = data.cartCount;
         await Swal.fire({
            icon:'success',
            title:data.message ,
            timer:2000
        })
      return;
    }
    Swal.fire({
        icon:'error',
        title:data.message,
        timer:2000
    })

  } catch (err) {
    Swal.fire({
        icon:'error',
        title:'Something went wrong'
    });
  }
}

//add to wishlist

async function addToWishlist(productId,variantId) {
     
  try {
    const res = await fetch(`/user/wishlist/add`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ productId ,variantId})
    });

    const data = await res.json();

    if (res.ok) {
        const wishlistBadge = document.getElementById('wishlist-count');
      if (wishlistBadge) wishlistBadge.textContent = data.wishlistCount;
         await Swal.fire({
            icon:'success',
            title:data.message ,
            timer:2000
        })
      return;
    }
    Swal.fire({
        icon:'error',
        title:data.message,
        timer:2000
    })

  } catch (err) {
    Swal.fire({
        icon:'error',
        title:'Something went wrong'
    });
  }
}
 
 //image zoom
 

const container = document.getElementById("imageZoomContainer");
        const image = document.getElementById("mainImage");

        const ZOOM_LEVEL = 2.5; // realistic zoom, not stupidly high

        container.addEventListener("mousemove", (e) => {
            const rect = container.getBoundingClientRect();

            const x = ((e.clientX - rect.left) / rect.width) * 100;
            const y = ((e.clientY - rect.top) / rect.height) * 100;

            image.style.transformOrigin = `${x}% ${y}%`;
            image.style.transform = `scale(${ZOOM_LEVEL})`;
        });

        container.addEventListener("mouseleave", () => {
            image.style.transformOrigin = "center center";
            image.style.transform = "scale(1)";
        });

        // Important: reset zoom when thumbnail changes
        function changeMainImage(imgUrl) {
            image.src = imgUrl;
            image.style.transform = "scale(1)";
            image.style.transformOrigin = "center center";
        }
    </script>



    <%- include("../partials/user/footer") %>