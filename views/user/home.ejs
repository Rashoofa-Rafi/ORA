

<%- include("../partials/user/header")%>
    <!-- Hero Section -->
    <section class="relative">
        <img src="/images/images.jpeg" alt="Hero" class="w-full object-cover h-[500px]">
        <div
            class="absolute inset-0 flex flex-col justify-center items-center text-center text-white bg-black bg-opacity-30">
            <h2 class="text-4xl md:text-5xl font-serif font-bold mb-4">TIMELESS ELEGANCE</h2>
            <p class="mb-6">Crafted for those who value precision</p>
            <a href="#" class="bg-yellow-400 text-black px-6 py-3 font-semibold rounded hover:bg-yellow-500">
                SHOP NOW
            </a>
        </div>
    </section>

    <!-- Category Section -->
    
    <section class="py-12 text-center">
    <h3 class="text-2xl md:text-3xl font-serif font-bold mb-6">
        GEN Z & MILLENNIAL APPROVED
    </h3>
    <p class="text-gray-600 mb-8">
        Minimal, Stunning & Trend Setting Global Fashion
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">

        <% categories.forEach(cat => { %>
            <div class="relative">
                <img src="<%= cat.image %>" 
 alt="<%= cat.name %>" class="w-full h-80 object-cover rounded"/>
                     <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2">
                    <a 
                        href="/view-all?category=<%= cat.name %>"
                        class="bg-gray-200 px-4 py-2 rounded shadow"
                    >
                        SHOP FOR <%= cat.name.toUpperCase() %>
                    </a>
                </div>
            </div>
        <% }) %>

    </div>
</section>


  <!-- Latest Trends -->
<section class="py-12 bg-gray-50">
  <h3 class="text-center text-2xl font-serif font-bold mb-8">LATEST TRENDS</h3>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-6xl mx-auto">
    <% latestProducts.forEach(product => { %>
      <div 
        class="bg-white shadow-lg rounded-lg overflow-hidden hover:shadow-2xl transition duration-300 cursor-pointer"
        onclick="window.location.href='/user/product-details/<%= product._id %>'"
      >
        <img src="<%= product.image %>" class="w-full h-56 object-cover" alt="<%= product.name %>">
        <div class="p-4">
          <h4 class="text-gray-800 font-semibold text-sm mb-2 truncate"><%= product.name %></h4>
          <% if(product.price !== 'N/A') { %>
            <p class="text-yellow-600 font-bold text-md">₹ <%= product.price %></p>
          <% } else { %>
            <p class="text-gray-400 text-md italic">Not Available</p>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<!-- Top Launches -->
<section class="py-12 bg-gray-50">
  <h3 class="text-center text-2xl font-serif font-bold mb-8">OUR TOP LAUNCHES</h3>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-6xl mx-auto">
    <% topLaunches.forEach(product => { %>
      <div 
        class="bg-white shadow-lg rounded-lg overflow-hidden hover:shadow-2xl transition duration-300 cursor-pointer"
        onclick="window.location.href='/user/product-details/<%= product._id %>'"
      >
        <img src="<%= product.image %>" class="w-full h-56 object-cover" alt="<%= product.name %>">
        <div class="p-4">
          <h4 class="text-gray-800 font-semibold text-sm mb-2 truncate"><%= product.name %></h4>
          <% if(product.price !== 'N/A') { %>
            <p class="text-yellow-600 font-bold text-md">₹ <%= product.price %></p>
          <% } else { %>
            <p class="text-gray-400 text-md italic">Not Available</p>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</section>



    <!-- Sale Section -->
    <section class="relative bg-gray-100">
        <div class="grid grid-cols-1 md:grid-cols-3 items-stretch">

            <!-- Left Side: Text -->
            <div class="flex flex-col justify-center px-6 md:px-12 py-20 bg-gray-100 md:col-span-1">
                <h3 class="text-6xl font-bold leading-tight mb-6">
                    <span class="text-gray-400">MEGA</span>
                    <span class="text-red-600">MAD</span>
                    <span class="text-gray-400">NESS</span>
                    <span class="text-yellow-400">SALE</span>
                </h3>


                <p class="text-3xl font-bold text-gray-900 bg-white/80 px-6 py-3 rounded shadow-lg inline-block">
                    FLAT 50% OFFER
                </p>
            </div>


            <div class="h-full w-full md:col-span-2">
                <img src="/images/sale.jpeg" alt="Sale Watch" class="w-full h-full object-cover">
            </div>

        </div>
    </section>
    <%- include("../partials/user/footer") %>




    