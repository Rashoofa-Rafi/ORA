      <i data-lucide="users" class="w-5 h-5 mr-3"></i> Referral
    </a> -->


    <a href="/admin/coupons" class="flex items-center px-6 py-2 rounded
       <%= currentPath === '/coupons' ? 'bg-black text-white' : 'text-gray-700 hover:bg-gray-100' %>">
      <i data-lucide="ticket" class="w-5 h-5 mr-3"></i> Coupon
    </a>



    <!-- <a href="/admin/refunds" class="flex items-center px-6 py-2 rounded
       <%= currentPath === '/refunds' ? 'bg-black text-white' : 'text-gray-700 hover:bg-gray-100' %>">
      <i data-lucide="rotate-ccw" class="w-5 h-5 mr-3"></i> Refund/Return
    </a> -->

    <a href="/admin/banners" class="flex items-center px-6 py-2 rounded
       <%= currentPath === '/banners' ? 'bg-black text-white' : 'text-gray-700 hover:bg-gray-100' %>">
      <i data-lucide="image" class="w-5 h-5 mr-3"></i> Banners
    </a>

    <a href="/admin/reviews" class="flex items-center px-6 py-2 rounded
