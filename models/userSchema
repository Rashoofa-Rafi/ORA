const mongoose=require("mongoose")


const userSchema=new mongoose.Schema({
    fullName:{
        type:String,
        required:true
     },
     email:{
        type:String,
        required:true,
        unique:true
     },
     mobile:{
        type:String,
        required:false,
        unique:false,
        sparse:true,
     },
     password:{
        type:String,
        required:true,
     },
     googleId:{
        type:String,
        //required:true
     },
     role:{
        type:String,
        enum:["user","admin"],
        default:'user'
     },
     isActive:{
        type:Boolean,
        required:false
     },
     walletBalance:{
        type:Number,
        //defualt:0
     },

   },
{ timestamps: true })
  
   





module.exports = mongoose.model("User", userSchema)